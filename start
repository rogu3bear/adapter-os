show_status() {
    echo ""
    echo -e "${FG_CYAN}adapterOS Service Status${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Check backend
    local backend_pid_file="$AOS_VAR_DIR/backend.pid"
    local backend_status="stopped"
    local backend_pid=""

    if [ -f "$backend_pid_file" ]; then
        backend_pid=$(cat "$backend_pid_file" 2>/dev/null)
        if [ -n "$backend_pid" ] && kill -0 "$backend_pid" 2>/dev/null; then
            backend_status="running"
        else
            # Stale PID file: fall back to the active listener so status remains accurate.
            backend_pid=$(lsof -nP -i :"$AOS_SERVER_PORT" -sTCP:LISTEN -t 2>/dev/null | head -1)
            if [ -n "$backend_pid" ]; then
                backend_status="running"
            fi
        fi
    else
        backend_pid=$(lsof -nP -i :"$AOS_SERVER_PORT" -sTCP:LISTEN -t 2>/dev/null | head -1)
        if [ -n "$backend_pid" ]; then
            backend_status="running"
        fi
    fi

    if [ "$backend_status" = "running" ]; then
        if curl -sf "http://localhost:$AOS_SERVER_PORT/healthz" >/dev/null 2>&1; then
            print_step "success" "Backend         ${FG_GREEN}HEALTHY${FG_RESET}  (PID $backend_pid, port $AOS_SERVER_PORT)"
        else
            print_step "running" "Backend         ${FG_YELLOW}STARTING${FG_RESET} (PID $backend_pid, port $AOS_SERVER_PORT)"
        fi
    else
        print_step "error" "Backend         ${FG_RED}STOPPED${FG_RESET}"
    fi

    # Check worker
    local worker_sock="$AOS_VAR_DIR/run/worker.sock"
    local worker_sock_abs="$worker_sock"
    if [[ "$worker_sock_abs" != /* ]]; then
        worker_sock_abs="$SCRIPT_DIR/$worker_sock_abs"
    fi
    local worker_pid_file="$AOS_VAR_DIR/worker.pid"
    if [ -S "$worker_sock" ] && lsof "$worker_sock_abs" >/dev/null 2>&1; then
        local worker_pid
        worker_pid=$(lsof -t "$worker_sock_abs" 2>/dev/null | head -1)
        if [ -n "$worker_pid" ] && kill -0 "$worker_pid" 2>/dev/null; then
            print_step "success" "Worker          ${FG_GREEN}RUNNING${FG_RESET}  (PID $worker_pid, socket)"
        else
            print_step "error" "Worker          ${FG_RED}STALE${FG_RESET}    (socket exists but process not running)"
        fi
    elif [ -f "$worker_pid_file" ]; then
        local worker_pid
        worker_pid=$(cat "$worker_pid_file" 2>/dev/null)
        if [ -n "$worker_pid" ] && kill -0 "$worker_pid" 2>/dev/null; then
            print_step "running" "Worker          ${FG_YELLOW}STARTING${FG_RESET} (PID $worker_pid, socket pending)"
        else
            print_step "error" "Worker          ${FG_RED}STOPPED${FG_RESET}  (stale PID file)"
        fi
    else
        print_step "pending" "Worker          ${FG_YELLOW}STOPPED${FG_RESET}  (optional)"
    fi

    echo ""

    # Database info
    local db_path="$AOS_VAR_DIR/aos-cp.sqlite3"
    if [ -f "$db_path" ]; then
        local size
        size=$(du -h "$db_path" 2>/dev/null | cut -f1)
        echo "  Database: $db_path ($size)"
    else
        echo "  Database: Not initialized"
    fi

    echo ""

    # Show URLs if running
    if [ "$backend_status" = "running" ]; then
        echo -e "${FG_CYAN}Access:${FG_RESET}"
        echo "  http://localhost:$AOS_SERVER_PORT  (API + UI)"
        echo ""
    fi
}

do_preflight() {
    if ! check_start_dependencies "preflight"; then
        return 1
    fi
    local failed=0

    if ! freeze_preflight "$AOS_SERVER_PORT" "$AOS_UI_PORT" "$AOS_VAR_DIR"; then
        failed=1
    fi

    if [ -x scripts/service-manager.sh ]; then
        if ! scripts/service-manager.sh preflight; then
            failed=1
        fi
    else
        fg_error "Missing required script: scripts/service-manager.sh"
        failed=1
    fi

    return "$failed"
}

binary_exists() {
    local path="$1"
    [ -f "$path" ] && [ -x "$path" ]
}

require_binary_or_cargo() {
    local label="$1"
    local debug_bin="$2"
    local release_bin="$3"

    if binary_exists "$debug_bin" || binary_exists "$release_bin"; then
        return 0
    fi

    if command -v cargo >/dev/null 2>&1; then
        return 0
    fi

    fg_error "Missing dependency for $label startup: no built binary and 'cargo' not found."
    echo "  Expected one of:"
    echo "    - $debug_bin"
    echo "    - $release_bin"
    echo "  Install Rust toolchain (cargo) or build binaries before running ./start."
    echo ""
    return 1
}

check_start_dependencies() {
    local mode="${1:-up}"
    local failed=0

    if ! command -v lsof >/dev/null 2>&1; then
        fg_error "Missing required command: lsof"
        echo "  ./start relies on lsof for deterministic port and process checks."
        echo ""
        failed=1
    fi

    case "$mode" in
        up|start|backend)
            if ! command -v curl >/dev/null 2>&1; then
                fg_error "Missing required command: curl"
                echo "  ./start uses curl for health and readiness checks."
                echo ""
                failed=1
            fi
            if [ ! -x scripts/service-manager.sh ]; then
                fg_error "Missing required script: scripts/service-manager.sh"
                echo ""
                failed=1
            fi
            if ! require_binary_or_cargo \
                "backend" \
                "$SCRIPT_DIR/target/debug/aos-server" \
                "$SCRIPT_DIR/target/release/aos-server"; then
                failed=1
            fi
            if [ "${SKIP_WORKER:-0}" != "1" ]; then
                if ! require_binary_or_cargo \
                    "worker" \
                    "$SCRIPT_DIR/target/debug/aos-worker" \
                    "$SCRIPT_DIR/target/release/aos-worker"; then
                    failed=1
                fi
            fi
            ;;
        worker)
            if [ ! -x scripts/service-manager.sh ]; then
                fg_error "Missing required script: scripts/service-manager.sh"
                echo ""
                failed=1
            fi
            if ! require_binary_or_cargo \
                "worker" \
                "$SCRIPT_DIR/target/debug/aos-worker" \
                "$SCRIPT_DIR/target/release/aos-worker"; then
                failed=1
            fi
            ;;
        secd)
            if [ ! -x scripts/service-manager.sh ]; then
                fg_error "Missing required script: scripts/service-manager.sh"
                echo ""
                failed=1
            fi
            if ! require_binary_or_cargo \
                "secd" \
                "$SCRIPT_DIR/target/debug/aos-secd" \
                "$SCRIPT_DIR/target/release/aos-secd"; then
                failed=1
            fi
            ;;
        node)
            if [ ! -x scripts/service-manager.sh ]; then
                fg_error "Missing required script: scripts/service-manager.sh"
                echo ""
                failed=1
            fi
            if ! require_binary_or_cargo \
                "node" \
                "$SCRIPT_DIR/target/debug/aos-node" \
                "$SCRIPT_DIR/target/release/aos-node"; then
                failed=1
            fi
            ;;
        preflight|check)
            # Port/process dependency checks only.
            ;;
    esac

    if [ "$failed" -ne 0 ]; then
        fg_error "Dependency preflight failed. Resolve missing items and retry."
        return 1
    fi

    return 0
}

# Start backend with progress animation
start_backend_animated() {
    log_line INFO "backend:start requested (port=$AOS_SERVER_PORT verbose=$VERBOSE trace=$TRACE)"

    ensure_var_dirs

    # Port checks may print diagnostics and/or prompt; never run them while an animation is active.
    if ! freeze_check_port "$AOS_SERVER_PORT" "Backend API" 2>/dev/null; then
        print_step "error" "Backend API - port $AOS_SERVER_PORT in use"
        log_line ERROR "backend:start blocked (port-in-use $AOS_SERVER_PORT)"
        return 1
    fi

    print_step "running" "Starting Backend API..."

    # Delegate to service-manager
    if [ -x scripts/service-manager.sh ]; then
        local tail_pid=""
        # Capture stderr to show helpful error messages (e.g., "binary not found")
        local service_manager_stderr
        service_manager_stderr=$(mktemp)
        start_spinner "Launching backend process..."
        if scripts/service-manager.sh start-backend >/dev/null 2>"$service_manager_stderr"; then
            stop_spinner
            rm -f "$service_manager_stderr"
            if [ $VERBOSE -eq 1 ] || [ $TRACE -eq 1 ]; then
                touch "$AOS_LOG_DIR/backend.log"
                tail -n 20 -F "$AOS_LOG_DIR/backend.log" &
                tail_pid=$!
            fi
            # Wait for backend startup with real phase-driven progress
            local health_timeout="${AOS_HEALTH_TIMEOUT:-15}"
            local backend_pid
            backend_pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)

            local poll_rc=0
            poll_backend_startup "$backend_pid" "$health_timeout" || poll_rc=$?

            case $poll_rc in
                0)
                    # Success
                    local pid
                    pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
                    if [ "$POLL_BOOT_STATE" = "degraded" ]; then
                        update_step "success" "Backend API     ${FG_YELLOW}DEGRADED${FG_RESET} (PID $pid, port $AOS_SERVER_PORT)"
                    else
                        update_step "success" "Backend API     ${FG_GREEN}READY${FG_RESET}  (PID $pid, port $AOS_SERVER_PORT)"
                    fi
                    log_line INFO "backend:ready pid=$pid port=$AOS_SERVER_PORT state=$POLL_BOOT_STATE"
                    if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
                    append_debug_log \
                        "start_backend_animated:health" \
                        "backend ready" \
                        "H1" \
                        "$(printf '{"pid":"%s","manifest":"%s","backend_port":"%s","boot_state":"%s"}' "$pid" "${AOS_MANIFEST_PATH:-}" "${AOS_SERVER_PORT:-18080}" "$POLL_BOOT_STATE")"
                    return 0
                    ;;
                2)
                    # Boot failure - structured error from server
                    update_step "error" "Backend API     ${FG_RED}BOOT FAILED${FG_RESET}"
                    echo ""
                    echo -e "  ${FG_RED}Backend boot failed${FG_RESET}"
                    [ -n "$POLL_FAIL_PHASE" ] && echo "    Failed phase:  $POLL_FAIL_PHASE"
                    [ -n "$POLL_FAIL_ERROR" ] && echo "    Error code:    $POLL_FAIL_ERROR"
                    [ -n "$POLL_FAIL_ACTION" ] && echo "    Next action:   $POLL_FAIL_ACTION"
                    echo ""
                    log_line ERROR "backend:boot_failed phase=${POLL_FAIL_PHASE:-unknown} error=${POLL_FAIL_ERROR:-unknown}"
                    [ "${AOS_BOOT_VERBOSE:-0}" = "1" ] && tail -30 "$AOS_VAR_DIR/logs/backend.log" 2>/dev/null
                    append_debug_log \
                        "start_backend_animated:boot_failed" \
                        "backend boot failed" \
                        "H1" \
                        "$(printf '{"failed_phase":"%s","error_code":"%s","next_action":"%s"}' "${POLL_FAIL_PHASE:-}" "${POLL_FAIL_ERROR:-}" "${POLL_FAIL_ACTION:-}")"
                    if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
                    return 1
                    ;;
                *)
                    # Crash or timeout
                    local pid
                    pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
                    if [ "$POLL_FAIL_REASON" = "CRASHED" ]; then
                        update_step "error" "Backend API     ${FG_RED}CRASHED${FG_RESET} (process died during startup)"
                        log_line ERROR "backend:early_crash pid=$backend_pid phase=${POLL_FAIL_PHASE:-unknown}"
                    elif [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                        update_step "error" "Backend API     ${FG_RED}UNHEALTHY${FG_RESET} (PID $pid, timeout after ${health_timeout}s at phase: ${POLL_FAIL_PHASE:-unknown})"
                        log_line ERROR "backend:health_timeout pid=$pid timeout=${health_timeout}s phase=${POLL_FAIL_PHASE:-unknown}"
                    else
                        update_step "error" "Backend API     ${FG_RED}CRASHED${FG_RESET} (process not running)"
                        log_line ERROR "backend:health_timeout pid=${pid:-none} timeout=${health_timeout}s"
                    fi
                    [ "${AOS_BOOT_VERBOSE:-0}" = "1" ] && tail -30 "$AOS_VAR_DIR/logs/backend.log" 2>/dev/null
                    append_debug_log \
                        "start_backend_animated:health_timeout" \
                        "backend startup failed" \
                        "H1" \
                        "$(printf '{"pid":"%s","reason":"%s","phase":"%s"}' "${pid:-}" "$POLL_FAIL_REASON" "${POLL_FAIL_PHASE:-}")"
                    if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
                    return 1
                    ;;
            esac
        else
            stop_spinner
            update_step "error" "Backend API - failed to start"
            log_line ERROR "backend:start failed (service-manager start-backend)"
            # Show helpful error messages from service-manager (e.g., "binary not found")
            if [ -s "$service_manager_stderr" ]; then
                echo ""
                echo "${FG_YELLOW}Error details:${FG_RESET}"
                cat "$service_manager_stderr" | sed 's/^/  /'
                echo ""
            fi
            rm -f "$service_manager_stderr"
            #region agent log
            append_debug_log \
                "start_backend_animated:error" \
                "backend start failed" \
                "H1" \
                "$(printf '{"manifest":"%s","backend_port":"%s"}' "${AOS_MANIFEST_PATH:-}" "${AOS_SERVER_PORT:-18080}")"
            #endregion agent log
            return 1
        fi
    else
        update_step "error" "Backend API - service-manager.sh not found"
        return 1
    fi
}

start_backend() {
    print_banner

    echo -e "${FG_CYAN}Starting Backend${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if [ -f target/build_id.txt ]; then
        echo -e "  Build:  ${FG_GREEN}$(cat target/build_id.txt)${FG_RESET}"
    fi
    echo -e "  Run ID: ${FG_CYAN}${AOS_RUN_ID}${FG_RESET}"
    echo ""

    ensure_var_dirs
    dump_env_summary
    check_stale_artifacts

    # Preflight
    if ! freeze_check_port "$AOS_SERVER_PORT" "Backend API"; then
        print_step "error" "Preflight failed (see details above)"
        return 1
    fi
    if ! freeze_check_pid_file "$AOS_VAR_DIR/backend.pid" "Backend"; then
        print_step "error" "Preflight failed (see details above)"
        return 1
    fi
