#!/bin/bash
# adapterOS Boot Script
#
# Usage:
#   ./start              Start backend + worker
#   ./start up           Same as above
#   ./start down         Graceful shutdown
#   ./start status       Show service status
#   ./start backend      Start backend only
#   ./start worker       Start worker only
#   ./start secd         Start Secure Enclave Daemon only
#   ./start node         Start Node Agent only
#   ./start preflight    Run system checks without starting
#   ./start help         Show this help
#
# UI: Backend serves Leptos WASM from static/. For dev, run `trunk serve`
#     in crates/adapteros-ui/ separately.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Source libraries
source scripts/lib/freeze-guard.sh
source scripts/lib/env-loader.sh

# Set SCRIPT_DIR for path normalization
export SCRIPT_DIR

# Unified Run ID for traceability
if command -v uuidgen > /dev/null; then
    export AOS_RUN_ID=${AOS_RUN_ID:-$(uuidgen)}
else
    export AOS_RUN_ID=${AOS_RUN_ID:-$(date +%s)-$(head -c 4 /dev/urandom | od -An -t x4 | tr -d ' ')}
fi
export AOS_DEBUG_RUN_ID=$AOS_RUN_ID

# Load .env file if it exists (provides default values)
# Values can still be overridden by environment variables set before running ./start
load_env_file ".env" --no-override || true

# Resolve server port from config when env is not set
read_server_port_from_config() {
    local config_path="$1"
    awk '
        $0 ~ /^\[server\]/ { in_server = 1; next }
        in_server && $0 ~ /^\[/ { in_server = 0 }
        in_server && $0 ~ /^[[:space:]]*port[[:space:]]*=/ {
            gsub(/#.*/, "", $0)
            split($0, a, "=")
            gsub(/[[:space:]]/, "", a[2])
            print a[2]
            exit
        }
    ' "$config_path"
}

read_dev_bypass_from_config() {
    local config_path="$1"
    awk '
        $0 ~ /^\[security\]/ { in_security = 1; next }
        in_security && $0 ~ /^\[/ { in_security = 0 }
        in_security && $0 ~ /^[[:space:]]*dev_bypass[[:space:]]*=/ {
            gsub(/#.*/, "", $0)
            split($0, a, "=")
            gsub(/[[:space:]]/, "", a[2])
            print a[2]
            exit
        }
    ' "$config_path"
}

if [ -z "${AOS_SERVER_PORT:-}" ]; then
    config_for_port="${AOS_CONFIG_PATH:-${AOS_CONFIG:-$SCRIPT_DIR/configs/cp.toml}}"
    if [ -f "$config_for_port" ]; then
        port_from_config="$(read_server_port_from_config "$config_for_port")"
        if [ -n "$port_from_config" ]; then
            AOS_SERVER_PORT="$port_from_config"
        fi
    fi
fi

if [ -z "${AOS_DEV_NO_AUTH:-}" ]; then
    config_for_dev_bypass="${AOS_CONFIG_PATH:-${AOS_CONFIG:-$SCRIPT_DIR/configs/cp.toml}}"
    if [ -f "$config_for_dev_bypass" ]; then
        dev_bypass_from_config="$(read_dev_bypass_from_config "$config_for_dev_bypass")"
        if [ "$dev_bypass_from_config" = "true" ]; then
            export AOS_DEV_NO_AUTH=1
        fi
    fi
fi

# Configuration (can be overridden via environment)
: "${AOS_SERVER_PORT:=8080}"
: "${AOS_VAR_DIR:=var}"
: "${AOS_LOG_DIR:=$AOS_VAR_DIR/logs}"
: "${SKIP_WORKER:=0}"
: "${SKIP_SECD:=0}"
: "${SKIP_NODE:=0}"
: "${AOS_QUICK_BOOT:=0}"
: "${AOS_VERIFY_CHAT:=0}"
: "${AOS_LOG_PROFILE:=json}"
: "${AOS_DEV_LOG_RETENTION_DAYS:=7}"
: "${AOS_DEV_CLIENT_ERROR_RETENTION_DAYS:=30}"

# Align control plane URL for worker registration if not set
: "${AOS_CP_URL:=http://127.0.0.1:$AOS_SERVER_PORT}"
export AOS_CP_URL

# Run quick validation (non-fatal, just warnings)
validate_env_quick || true

VERBOSE=0
TRACE=0
SCRIPT_LOG="$AOS_LOG_DIR/start.log"
READYZ_TIMELINE_PATH="$AOS_LOG_DIR/readyz-timeline.jsonl"
DEBUG_LOG_PATH="$AOS_LOG_DIR/debug.jsonl"

# Animation characters
SPINNER_CHARS="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
PROGRESS_CHARS="▁▂▃▄▅▆▇█"
CHECK_MARK="✓"
CROSS_MARK="✗"
ARROW="→"

# Progress tracking
BOOT_PROGRESS_CURRENT=0
BOOT_PROGRESS_TOTAL=100
BOOT_PROGRESS_STEPS=()

# =============================================================================
# Animation & Progress Helpers
# =============================================================================

# If stdout is a TTY, we can safely animate using in-place row updates.
# If not (CI, redirected output), suppress in-place animations to avoid log spam.
AOS_CAN_ANIMATE=0
if [ -t 1 ] && [ "${AOS_NO_ANIMATION:-0}" != "1" ]; then
    AOS_CAN_ANIMATE=1
fi

# Clear exactly one terminal row (current line) and return carriage to column 0.
term_clear_row() {
    [ "$AOS_CAN_ANIMATE" -eq 1 ] || return 0
    printf "\r\033[2K"
}

# Print the adapterOS banner
print_banner() {
    echo ""
    printf "${FG_CYAN}"
    cat << 'EOF'
    ___       __            __            ____  _____
   /   | ____/ /___ _____  / /____  _____/ __ \/ ___/
  / /| |/ __  / __ `/ __ \/ __/ _ \/ ___/ / / /\__ \
 / ___ / /_/ / /_/ / /_/ / /_/  __/ /  / /_/ /___/ /
/_/  |_\__,_/\__,_/ .___/\__/\___/_/   \____//____/
                 /_/
EOF
    printf "${FG_RESET}"
    echo ""
}

# Spinner animation for background tasks
# Usage: start_spinner "message" ; do_work ; stop_spinner
SPINNER_PID=""
start_spinner() {
    local msg="$1"
    if [ "$AOS_CAN_ANIMATE" -ne 1 ]; then
        # Non-interactive output: emit a single line and skip background animation.
        echo "  $msg"
        SPINNER_PID=""
        return 0
    fi
    (
        local i=0
        while true; do
            term_clear_row
            printf "  ${FG_CYAN}${SPINNER_CHARS:$i:1}${FG_RESET} %s" "$msg"
            i=$(( (i + 1) % ${#SPINNER_CHARS} ))
            sleep 0.1
        done
    ) &
    SPINNER_PID=$!
    disown
}

stop_spinner() {
    if [ -n "$SPINNER_PID" ]; then
        kill "$SPINNER_PID" 2>/dev/null || true
        wait "$SPINNER_PID" 2>/dev/null || true
        SPINNER_PID=""
        term_clear_row
    fi
}

# Print a step with status
print_step() {
    local status="$1"  # pending, running, success, error
    local msg="$2"

    # If a progress/spinner line was just rendered without a newline, make sure
    # this step starts on a clean single row.
    term_clear_row

    case "$status" in
        pending)
            echo -e "  ${FG_YELLOW}○${FG_RESET} $msg"
            ;;
        running)
            echo -e "  ${FG_CYAN}◐${FG_RESET} $msg"
            ;;
        success)
            echo -e "  ${FG_GREEN}${CHECK_MARK}${FG_RESET} $msg"
            ;;
        error)
            echo -e "  ${FG_RED}${CROSS_MARK}${FG_RESET} $msg"
            ;;
    esac
}

# Update a step in place (moves cursor up)
update_step() {
    local status="$1"
    local msg="$2"
    if [ "$AOS_CAN_ANIMATE" -ne 1 ]; then
        # Non-interactive output: don't emit cursor movement/clear escapes.
        print_step "$status" "$msg"
        return 0
    fi

    # Move up one row (the previously printed step) and clear exactly that row.
    printf "\033[1A\033[2K"
    print_step "$status" "$msg"
}

# Animated progress bar with smooth animation
print_progress() {
    local current="$1"
    local total="$2"
    [ "$total" -eq 0 ] && total=1  # Avoid division by zero
    local width=40
    local pct=$((current * 100 / total))
    [ $pct -gt 100 ] && pct=100  # Cap at 100%
    local filled=$((current * width / total))
    [ $filled -gt $width ] && filled=$width  # Cap at width
    local empty=$((width - filled))

    term_clear_row
    printf "  ${FG_CYAN}[${FG_RESET}"
    if [ $filled -gt 0 ]; then
        printf "${FG_GREEN}%${filled}s${FG_RESET}" | tr ' ' '█'
    fi
    if [ $filled -lt $width ]; then
        printf "%${empty}s" | tr ' ' '░'
    fi
    printf "${FG_CYAN}]${FG_RESET} ${FG_BOLD}%3d%%${FG_RESET}" "$pct"
}

# Animated progress bar with spinner overlay
print_progress_animated() {
    local current="$1"
    local total="$2"
    local msg="${3:-}"
    [ "$AOS_CAN_ANIMATE" -eq 1 ] || return 0
    [ "$total" -eq 0 ] && total=1  # Avoid division by zero
    local width=40
    local pct=$((current * 100 / total))
    [ $pct -gt 100 ] && pct=100  # Cap at 100%
    local filled=$((current * width / total))
    [ $filled -gt $width ] && filled=$width  # Cap at width
    local empty=$((width - filled))
    
    # Get spinner character
    local spinner_idx=$((current % ${#SPINNER_CHARS}))
    local spinner_char="${SPINNER_CHARS:$spinner_idx:1}"

    term_clear_row
    printf "  ${FG_CYAN}${spinner_char}${FG_RESET} ${FG_CYAN}[${FG_RESET}"
    printf "${FG_GREEN}%${filled}s${FG_RESET}" | tr ' ' '█'
    printf "%${empty}s" | tr ' ' '░'
    printf "${FG_CYAN}]${FG_RESET} ${FG_BOLD}%3d%%${FG_RESET}" "$pct"
    if [ -n "$msg" ]; then
        printf " ${FG_CYAN}%s${FG_RESET}" "$msg"
    fi
}

# Boot progress tracker
init_boot_progress() {
    BOOT_PROGRESS_CURRENT=0
    BOOT_PROGRESS_TOTAL=100
    BOOT_PROGRESS_STEPS=(
        "preflight:10"
        "backend_start:25"
        "backend_health:35"
        "model_seed:45"
        "worker_start:60"
        "worker_ready:75"
        "model_load:85"
        "inference_check:90"
        "chat_verify:95"
        "complete:100"
    )
}

update_boot_progress() {
    local step="$1"
    local target_pct=0
    
    # Find target percentage for this step
    for step_def in "${BOOT_PROGRESS_STEPS[@]}"; do
        local step_name="${step_def%%:*}"
        local step_pct="${step_def##*:}"
        if [ "$step_name" = "$step" ]; then
            target_pct=$step_pct
            break
        fi
    done
    
    # Smoothly animate to target
    while [ $BOOT_PROGRESS_CURRENT -lt $target_pct ]; do
        BOOT_PROGRESS_CURRENT=$((BOOT_PROGRESS_CURRENT + 2))
        if [ $BOOT_PROGRESS_CURRENT -gt $target_pct ]; then
            BOOT_PROGRESS_CURRENT=$target_pct
        fi
        print_progress_animated "$BOOT_PROGRESS_CURRENT" "$BOOT_PROGRESS_TOTAL" "Boot progress"
        sleep 0.05
    done
}

# Enhanced progress bar for operations with time estimate
print_progress_with_time() {
    local current="$1"
    local total="$2"
    local elapsed="$3"
    local msg="${4:-}"
    [ "$AOS_CAN_ANIMATE" -eq 1 ] || return 0
    [ "$total" -eq 0 ] && total=1  # Avoid division by zero
    local width=40
    local pct=$((current * 100 / total))
    [ $pct -gt 100 ] && pct=100  # Cap at 100%
    local filled=$((current * width / total))
    [ $filled -gt $width ] && filled=$width  # Cap at width
    local empty=$((width - filled))
    
    # Estimate remaining time
    local remaining=""
    if [ $current -gt 0 ] && [ $elapsed -gt 0 ]; then
        local rate=$((current * 1000 / elapsed))
        if [ $rate -gt 0 ]; then
            local remaining_ms=$(((total - current) * 1000 / rate))
            if [ $remaining_ms -lt 1000 ]; then
                remaining="${remaining_ms}ms"
            elif [ $remaining_ms -lt 60000 ]; then
                remaining="$((remaining_ms / 1000))s"
            else
                remaining="$((remaining_ms / 60000))m"
            fi
        fi
    fi

    term_clear_row
    printf "  ${FG_CYAN}[${FG_RESET}"
    printf "${FG_GREEN}%${filled}s${FG_RESET}" | tr ' ' '█'
    printf "%${empty}s" | tr ' ' '░'
    printf "${FG_CYAN}]${FG_RESET} ${FG_BOLD}%3d%%${FG_RESET}" "$pct"
    if [ -n "$msg" ]; then
        printf " ${FG_CYAN}%s${FG_RESET}" "$msg"
    fi
    if [ -n "$remaining" ]; then
        printf " ${FG_YELLOW}(~${remaining})${FG_RESET}"
    fi
}

# Wait for service to be ready with animation
wait_for_service() {
    local name="$1"
    local check_cmd="$2"
    local timeout="${3:-30}"
    local msg="$4"

    print_step "running" "$msg"

    local waited=0
    while [ $waited -lt $timeout ]; do
        if eval "$check_cmd" >/dev/null 2>&1; then
            update_step "success" "$msg"
            return 0
        fi
        sleep 1
        ((waited++))
    done

    update_step "error" "$msg (timeout)"
    return 1
}

# =============================================================================
# aosctl Installation
# =============================================================================

AOSCTL_INSTALLED_FLAG="$AOS_VAR_DIR/.aosctl-path-offered"

check_aosctl_installation() {
    # Skip if we've already offered
    if [ -f "$AOSCTL_INSTALLED_FLAG" ]; then
        return 0
    fi

    # Skip if aosctl is already in PATH
    if command -v aosctl >/dev/null 2>&1; then
        touch "$AOSCTL_INSTALLED_FLAG"
        return 0
    fi

    # Check if we have a built aosctl
    local aosctl_bin=""
    if [ -f "target/release/aosctl" ]; then
        aosctl_bin="target/release/aosctl"
    elif [ -f "target/debug/aosctl" ]; then
        aosctl_bin="target/debug/aosctl"
    else
        # No binary to install
        return 0
    fi

    echo ""
    echo -e "${FG_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
    echo ""
    echo -e "  ${FG_YELLOW}aosctl${FG_RESET} is not in your PATH."
    echo ""
    echo "  The aosctl CLI provides commands for managing adapters, training,"
    echo "  inference, and system administration."
    echo ""
    echo "  Options:"
    echo -e "    ${FG_GREEN}1${FG_RESET}) Install to /usr/local/bin (requires sudo)"
    echo -e "    ${FG_GREEN}2${FG_RESET}) Install to ~/bin (no sudo required)"
    echo -e "    ${FG_GREEN}3${FG_RESET}) Add to PATH via shell config (~/.zshrc or ~/.bashrc)"
    echo -e "    ${FG_GREEN}s${FG_RESET}) Skip (you can always use ./aosctl)"
    echo ""

    read -p "  Choose an option [1/2/3/s]: " -n 1 -r choice
    echo ""

    case "$choice" in
        1)
            echo ""
            print_step "running" "Installing aosctl to /usr/local/bin..."
            if sudo ln -sf "$(pwd)/$aosctl_bin" /usr/local/bin/aosctl 2>/dev/null; then
                # sudo may prompt; avoid cursor-up rewrites which can corrupt the prompt line.
                print_step "success" "Installed aosctl to /usr/local/bin"
                echo ""
                echo "  You can now run: ${FG_GREEN}aosctl --help${FG_RESET}"
            else
                print_step "error" "Failed to install (try option 2 or 3)"
            fi
            ;;
        2)
            echo ""
            mkdir -p "$HOME/bin"
            print_step "running" "Installing aosctl to ~/bin..."
            ln -sf "$(pwd)/$aosctl_bin" "$HOME/bin/aosctl"
            update_step "success" "Installed aosctl to ~/bin"

            # Check if ~/bin is in PATH
            if [[ ":$PATH:" != *":$HOME/bin:"* ]]; then
                echo ""
                echo -e "  ${FG_YELLOW}Note:${FG_RESET} ~/bin is not in your PATH."
                echo "  Add this to your ~/.zshrc or ~/.bashrc:"
                echo ""
                echo -e "    ${FG_CYAN}export PATH=\"\$HOME/bin:\$PATH\"${FG_RESET}"
                echo ""
            else
                echo ""
                echo "  You can now run: ${FG_GREEN}aosctl --help${FG_RESET}"
            fi
            ;;
        3)
            echo ""
            local shell_rc=""
            if [ -n "$ZSH_VERSION" ] || [ -f "$HOME/.zshrc" ]; then
                shell_rc="$HOME/.zshrc"
            else
                shell_rc="$HOME/.bashrc"
            fi

            local aos_path="export PATH=\"$(pwd):\$PATH\"  # adapterOS"

            if grep -q "adapterOS" "$shell_rc" 2>/dev/null; then
                print_step "success" "PATH already configured in $shell_rc"
            else
                print_step "running" "Adding to $shell_rc..."
                echo "" >> "$shell_rc"
                echo "# adapterOS CLI" >> "$shell_rc"
                echo "$aos_path" >> "$shell_rc"
                update_step "success" "Added to $shell_rc"
                echo ""
                echo "  Run this to apply now: ${FG_CYAN}source $shell_rc${FG_RESET}"
                echo "  Or start a new terminal."
            fi
            ;;
        s|S|"")
            echo ""
            echo "  Skipped. You can use ${FG_CYAN}./aosctl${FG_RESET} from this directory."
            ;;
    esac

    # Mark as offered
    mkdir -p "$AOS_VAR_DIR"
    touch "$AOSCTL_INSTALLED_FLAG"
    echo ""
    echo -e "${FG_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
    echo ""
}

# =============================================================================
# Core Functions
# =============================================================================

ensure_var_dirs() {
    mkdir -p "$AOS_VAR_DIR/run"
    mkdir -p "$AOS_LOG_DIR"
    ensure_backend_log_alias
}

ensure_backend_log_alias() {
    local alias="$AOS_LOG_DIR/server.log"
    local backend="$AOS_LOG_DIR/backend.log"

    if [ -L "$alias" ]; then
        ln -sfn "backend.log" "$alias"
        return
    fi

    if [ -e "$alias" ]; then
        if [ ! -e "$backend" ]; then
            mv "$alias" "$backend"
        else
            local ts
            ts=$(date +%s)
            mv "$alias" "${alias}.legacy.${ts}"
        fi
    fi

    if [ ! -e "$alias" ]; then
        ln -s "backend.log" "$alias"
    fi
}

rotate_boot_logs() {
    ensure_var_dirs
    local max_bytes=2097152  # ~2MB
    for f in "$SCRIPT_LOG" "$DEBUG_LOG_PATH" "$READYZ_TIMELINE_PATH"; do
        [ -f "$f" ] || continue
        local size
        size=$(wc -c < "$f" 2>/dev/null | tr -d ' ')
        if [ -n "$size" ] && [ "$size" -gt "$max_bytes" ]; then
            mv "$f" "${f}.prev"
        fi
    done
}

run_dev_log_hygiene() {
    ensure_var_dirs

    # Rotate boot logs if they exceed ~2MB
    rotate_boot_logs

    local log_retention_days="${AOS_DEV_LOG_RETENTION_DAYS:-7}"
    local db_retention_days="${AOS_DEV_CLIENT_ERROR_RETENTION_DAYS:-30}"

    if ! [[ "$log_retention_days" =~ ^[0-9]+$ ]]; then
        log_line WARN "hygiene:invalid_log_retention '$log_retention_days' (using 7)"
        log_retention_days=7
    fi
    if ! [[ "$db_retention_days" =~ ^[0-9]+$ ]]; then
        log_line WARN "hygiene:invalid_db_retention '$db_retention_days' (using 30)"
        db_retention_days=30
    fi

    local logs_pruned=0
    if [ -d "$AOS_LOG_DIR" ]; then
        while IFS= read -r stale_log; do
            [ -z "$stale_log" ] && continue
            if rm -f "$stale_log"; then
                logs_pruned=$((logs_pruned + 1))
            fi
        done < <(
            find "$AOS_LOG_DIR" \
                -maxdepth 1 \
                -type f \
                \( \
                    -name "*.log" \
                    -o -name "*.err" \
                    -o -name "*.out" \
                    -o -name "*.json" \
                    -o -name "*.jsonl" \
                    -o -name "*.ndjson" \
                    -o -name "aos-cp.*" \
                    -o -name "aos-worker.*" \
                    -o -name "worker-demo.*" \
                \) \
                -mtime +"$log_retention_days" \
                -print 2>/dev/null || true
        )
    fi

    local client_errors_pruned="skip-no-db"
    local db_path="$AOS_VAR_DIR/aos-cp.sqlite3"
    if [ -f "$db_path" ]; then
        if command -v sqlite3 >/dev/null 2>&1; then
            local sql_output=""
            if sql_output=$(
                sqlite3 "$db_path" \
                    "DELETE FROM client_errors WHERE created_at < datetime('now', '-${db_retention_days} days'); SELECT changes();" \
                    2>/dev/null
            ); then
                client_errors_pruned="$(printf '%s\n' "$sql_output" | tail -n1 | tr -d '[:space:]')"
                [ -z "$client_errors_pruned" ] && client_errors_pruned=0
            else
                client_errors_pruned="error"
                log_line WARN "hygiene:sqlite_prune_failed db=$db_path"
            fi
        else
            client_errors_pruned="skip-no-sqlite3"
            log_line WARN "hygiene:sqlite3_missing client_errors_prune_skipped"
        fi
    fi

    log_line INFO "hygiene:retention log_days=$log_retention_days db_days=$db_retention_days logs_pruned=$logs_pruned client_errors_pruned=$client_errors_pruned"
}

now_ms() {
    # macOS `date` lacks %N, so multiply seconds to avoid Python
    echo $(( $(date +%s) * 1000 ))
}

append_debug_log() {
    local location="$1"
    local message="$2"
    local hypothesis="$3"
    local data_json="${4:-{}}"

    ensure_var_dirs
    mkdir -p "$(dirname "$DEBUG_LOG_PATH")"
    local ts_ms
    ts_ms=$(now_ms)

    if command -v jq >/dev/null 2>&1; then
        jq -nc \
            --arg session "debug-session" \
            --arg runId "${AOS_RUN_ID:-pre-fix}" \
            --arg hyp "${hypothesis:-}" \
            --arg loc "$location" \
            --arg msg "$message" \
            --argjson data "$data_json" \
            --arg ts "$ts_ms" \
            '{sessionId:$session, runId:$runId, hypothesisId:$hyp, location:$loc, message:$msg, data:$data, timestamp: ($ts|tonumber)}' \
            >>"$DEBUG_LOG_PATH" 2>/dev/null && return
    fi

    printf '{"sessionId":"%s","runId":"%s","hypothesisId":"%s","location":"%s","message":"%s","data":%s,"timestamp":%s}\n' \
        "debug-session" "${AOS_RUN_ID:-pre-fix}" "${hypothesis:-}" "$location" "$message" "${data_json:-{}}" "$ts_ms" \
        >>"$DEBUG_LOG_PATH"
}

log_line() {
    local level="$1"; shift
    local msg="$*"
    ensure_var_dirs
    local ts
    ts=$(date -Iseconds)
    local line="[$ts] [$level] [start] [$AOS_RUN_ID] $msg"
    echo -e "$line"
    echo -e "$line" >>"$SCRIPT_LOG"
}

log_readyz_timeline() {
    local status="$1"
    local body="$2"
    ensure_var_dirs
    mkdir -p "$(dirname "$READYZ_TIMELINE_PATH")"
    local ts_ms
    ts_ms=$(now_ms)

    if command -v jq >/dev/null 2>&1; then
        local parsed_body
        if printf '%s' "$body" | jq -e . >/dev/null 2>&1; then
            parsed_body=$(printf '%s' "$body" | jq -c .)
        else
            parsed_body=$(printf '%s' "$body" | jq -R -c .)
        fi
        jq -nc \
            --arg ts "$ts_ms" \
            --arg status "$status" \
            --argjson body "$parsed_body" \
            '{ts_ms: ($ts|tonumber), status: $status, body: $body}' \
            >>"$READYZ_TIMELINE_PATH" 2>/dev/null && return
    fi

    # Fallback: log as a flat string if jq is unavailable
    local safe_body="${body//\"/\\\"}"
    printf '{"ts_ms":%s,"status":"%s","body":"%s"}\n' "$ts_ms" "$status" "$safe_body" \
        >>"$READYZ_TIMELINE_PATH"
}

dump_env_summary() {
