    # Offer aosctl installation
    check_aosctl_installation
}

start_all() {
    BOOT_IN_PROGRESS=1

    # First-boot detection: if no manifest exists and we're interactive, offer to generate one
    if ! manifest_exists "$AOS_MANIFEST_FILE" && [ -t 0 ] && [ "${AOS_SKIP_INIT:-0}" != "1" ]; then
        print_banner
        echo ""
        echo -e "  ${FG_YELLOW}No system manifest found.${FG_RESET}"
        echo -e "  A manifest configures your adapterOS instance (services, model, ports)."
        echo ""
        printf "  Generate one now? [Y/n]: "
        local init_choice
        read -r init_choice
        init_choice="${init_choice:-Y}"
        case "$init_choice" in
            [Yy]|[Yy]es)
                source scripts/lib/manifest-wizard.sh
                run_manifest_wizard
                # Re-bridge after generating manifest
                bridge_manifest_to_env
                ;;
            *)
                echo -e "  ${FG_CYAN}Skipping.${FG_RESET} Run ${FG_BOLD}./start init${FG_RESET} later to generate a manifest."
                echo ""
                ;;
        esac
    fi

    print_banner

    echo ""
    echo -e "${FG_CYAN}Starting adapterOS${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if [ -f target/build_id.txt ]; then
        echo -e "  Build:  ${FG_GREEN}$(cat target/build_id.txt)${FG_RESET}"
    fi
    echo -e "  Run ID: ${FG_CYAN}${AOS_RUN_ID}${FG_RESET}"
    echo ""

    # Check for stale build cache (warns if >48h or >50GB; do not fail boot)
    if [ -x "scripts/check_cache_staleness.sh" ]; then
        cache_warn="$(scripts/check_cache_staleness.sh 2>&1 || true)"
        if [ -n "${cache_warn:-}" ]; then
            term_clear_row
            printf "%s\n" "$cache_warn"
        fi
    elif command -v cargo >/dev/null 2>&1 && [ -f "xtask/src/check_cache.rs" ]; then
        cargo xtask check-cache 2>/dev/null || true
    fi

    ensure_var_dirs

    #region agent log
    append_debug_log \
        "start_all:env" \
        "start_all entry" \
        "H4" \
        "$(printf '{"AOS_SERVER_PORT":"%s","AOS_MANIFEST_PATH":"%s","AOS_MODEL_BACKEND":"%s","SKIP_WORKER":"%s"}' "${AOS_SERVER_PORT:-18080}" "${AOS_MANIFEST_PATH:-}" "${AOS_MODEL_BACKEND:-}" "${SKIP_WORKER:-0}")"
    #endregion agent log

    # Preflight with animation
    print_step "running" "Running preflight checks..."
    log_line INFO "preflight:start"

    local preflight_failed=0
    local preflight_start=$(date +%s)

    # Port checks (avoid printing progress here; freeze_check_port may emit diagnostics/prompts)
    if ! freeze_check_port "$AOS_SERVER_PORT" "Backend API"; then
        preflight_failed=1
        log_line WARN "preflight:backend_port_busy port=$AOS_SERVER_PORT"
    fi

    log_line INFO "preflight:complete status=$preflight_failed"

    if [ $preflight_failed -eq 1 ]; then
        print_step "error" "Preflight checks failed (see above)"
        echo ""
        echo "  Run ${FG_CYAN}./start preflight${FG_RESET} for details"
        return 1
    fi

    print_step "success" "Preflight checks passed"
    echo ""

    # Start services
    local backend_ok=0
    local worker_ok=0

    start_backend_animated && backend_ok=1
    if [ $backend_ok -eq 1 ]; then
        check_ui_assets || true
    fi

    # Seed model into database if AOS_MODEL_PATH is set
    if [ $backend_ok -eq 1 ] && [ -n "${AOS_MODEL_PATH:-}" ]; then
        print_step "running" "Seeding model into database..."
        local aosctl_bin=""
        if [ -f "./aosctl" ]; then
            aosctl_bin="./aosctl"
        elif [ -f "target/debug/aosctl" ]; then
            aosctl_bin="target/debug/aosctl"
        elif [ -f "target/release/aosctl" ]; then
            aosctl_bin="target/release/aosctl"
        fi

        if [ -n "$aosctl_bin" ]; then
            local existing_model_id=""
            if existing_model_id="$(resolve_model_id_for_model_path "$AOS_MODEL_PATH" 2>/dev/null)"; then
                update_step "pending" "Model seeding  ${FG_YELLOW}SKIPPED${FG_RESET}  (already seeded: ${existing_model_id})"
            else
                start_spinner "Seeding model..."
                if "$aosctl_bin" models seed --model-path "$AOS_MODEL_PATH" >/dev/null 2>&1; then
                    stop_spinner
                    update_step "success" "Model seeded"
                else
                    stop_spinner
                    update_step "pending" "Model seeding  ${FG_YELLOW}SKIPPED${FG_RESET}  (already exists or error)"
                fi
            fi
        else
            update_step "pending" "Model seeding  ${FG_YELLOW}SKIPPED${FG_RESET}  (aosctl not found)"
        fi
    fi

    # Start worker (required by default, use --skip-worker to opt out)
    print_step "running" "Starting Inference Worker..."
    if [ "${SKIP_WORKER:-0}" = "1" ]; then
        update_step "pending" "Worker          ${FG_YELLOW}SKIPPED${FG_RESET}  (requested via --skip-worker)"
    elif scripts/service-manager.sh start worker >/dev/null 2>&1; then
        # Wait for worker with phase-aware progress milestones
        local waited=0
        local worker_timeout=15
        local worker_pid
        worker_pid=$(cat "$AOS_VAR_DIR/worker.pid" 2>/dev/null)
        local worker_phase="starting"

        while [ $waited -lt $worker_timeout ]; do
            # Early crash detection
            if [ -n "$worker_pid" ] && ! kill -0 "$worker_pid" 2>/dev/null; then
                term_clear_row
                update_step "error" "Worker          ${FG_RED}CRASHED${FG_RESET} (process died during startup)"
                log_line ERROR "worker:early_crash pid=$worker_pid"
                [ "${AOS_BOOT_VERBOSE:-0}" = "1" ] && tail -30 "$AOS_VAR_DIR/logs/worker.log" 2>/dev/null
                append_debug_log \
                    "start_all:worker_early_crash" \
                    "worker crashed during socket wait" \
                    "H3" \
                    "$(printf '{"pid":"%s"}' "$worker_pid")"
                echo ""
                echo -e "  ${FG_RED}Worker crashed during startup.${FG_RESET} Check logs:"
                echo "    tail -50 $AOS_VAR_DIR/logs/worker.log"
                echo ""
                return 1
            fi

            # Determine worker phase and percentage
            local wpct=15
            local wlabel="Starting worker process..."
            if [ -S "$AOS_VAR_DIR/run/worker.sock" ]; then
                local worker_sock_abs="$AOS_VAR_DIR/run/worker.sock"
                if [[ "$worker_sock_abs" != /* ]]; then
                    worker_sock_abs="$SCRIPT_DIR/$worker_sock_abs"
                fi

                # Socket exists - check if listener is attached
                local socket_pid=""
                if command -v lsof >/dev/null 2>&1; then
                    socket_pid=$(lsof -t "$worker_sock_abs" 2>/dev/null | head -1)
                fi

                if [ -n "$socket_pid" ] && kill -0 "$socket_pid" 2>/dev/null; then
                    # Socket + live listener - check DB status for full readiness
                    local db_worker_status=""
                    if command -v sqlite3 >/dev/null 2>&1 && [ -f "$AOS_VAR_DIR/aos-cp.sqlite3" ]; then
                        db_worker_status=$(sqlite3 "$AOS_VAR_DIR/aos-cp.sqlite3" \
                            "SELECT status FROM workers WHERE pid=$worker_pid ORDER BY started_at DESC LIMIT 1;" \
                            2>/dev/null | head -1)
                    fi

                    case "$db_worker_status" in
                        healthy|serving)
                            # Fully ready
                            term_clear_row
                            update_step "success" "Worker          ${FG_GREEN}READY${FG_RESET}  (PID $socket_pid, socket)"
                            worker_ok=1
                            break
                            ;;
                        *)
                            wpct=75
                            wlabel="Registered with control plane..."
                            ;;
                    esac
                else
                    # Socket exists but no listener yet (race during bind)
                    wpct=50
                    wlabel="Socket bound, registering..."
                fi
            fi

            if [ "$AOS_CAN_ANIMATE" -eq 1 ]; then
                print_progress_animated "$wpct" 100 "$wlabel"
            elif [ "$worker_phase" != "$wlabel" ]; then
                echo "  [$wpct%] $wlabel"
                worker_phase="$wlabel"
            fi

            sleep 1
            ((waited++))
        done
        if [ $worker_ok -eq 0 ]; then
            term_clear_row
            update_step "error" "Worker          ${FG_RED}NOT READY${FG_RESET} (socket missing after ${worker_timeout}s)"
            log_line ERROR "worker:socket_timeout timeout=${worker_timeout}s"
            return 1
        fi
    else
        update_step "error" "Worker          ${FG_RED}FAILED${FG_RESET}  - inference not available"
        echo ""
        echo -e "  ${FG_RED}Worker startup failed.${FG_RESET} Possible causes:"
        echo "    - Worker binary not built: cargo build -p adapteros-lora-worker"
        echo "    - Manifest not found: set AOS_WORKER_MANIFEST"
        echo "    - Model not found: set AOS_MODEL_PATH"
        echo ""
        echo -e "  To skip worker: ${FG_CYAN}./start --skip-worker${FG_RESET}"
        echo ""
        return 1
    fi

    #region agent log
    append_debug_log \
        "start_all:worker" \
        "worker start result" \
        "H3" \
        "$(printf '{"skip_worker":"%s","worker_socket_exists":%s,"worker_ok":%s}' \
            "${SKIP_WORKER:-0}" \
            "$( [ -S \"$AOS_VAR_DIR/run/worker.sock\" ] && echo true || echo false )" \
            "$( [ "$worker_ok" -eq 1 ] && echo true || echo false )" \
        )"
    #endregion agent log

    # Ensure the active base model is marked loaded on the worker so /v1/infer works immediately.
    # This is intentionally conservative (dev/demo quality-of-life) and only runs when:
    # - backend + worker are up
    # - a model path is provided
    # Skip when AOS_QUICK_BOOT=1 (--quick): worker loads on first inference; avoids 409 hot-swap gate loop
    if [ "${AOS_QUICK_BOOT:-0}" = "1" ]; then
        update_step "pending" "Model           ${FG_YELLOW}SKIPPED${FG_RESET}  (--quick: loads on first inference)"
    elif [ $backend_ok -eq 1 ] && [ $worker_ok -eq 1 ] && [ -n "${AOS_MODEL_PATH:-}" ]; then
        print_step "running" "Loading base model on worker..."
        if load_seeded_model_on_worker "$AOS_MODEL_PATH"; then
            local mem_info=""
            if [ -n "$MODEL_LOAD_MEMORY_MB" ] && [ "$MODEL_LOAD_MEMORY_MB" != "0" ]; then
                # Format memory: show as GB if >= 1024 MB, otherwise MB
                if [ "$MODEL_LOAD_MEMORY_MB" -ge 1024 ] 2>/dev/null; then
                    local gb_whole=$((MODEL_LOAD_MEMORY_MB / 1024))
                    local gb_frac=$(( (MODEL_LOAD_MEMORY_MB % 1024) * 10 / 1024 ))
                    mem_info="  (${gb_whole}.${gb_frac} GB)"
                else
                    mem_info="  (${MODEL_LOAD_MEMORY_MB} MB)"
                fi
            fi
            update_step "success" "Model           ${FG_GREEN}LOADED${FG_RESET}${mem_info}"
        else
            update_step "error" "Model           ${FG_RED}NOT LOADED${FG_RESET}"
            echo ""
            echo "  Check:"
            echo "    curl -s http://localhost:$AOS_SERVER_PORT/readyz"
            echo "    tail -50 $AOS_VAR_DIR/logs/worker.log"
            echo ""
            return 1
        fi
    fi

    # Start SecD (Secure Enclave Daemon) - optional
    local secd_ok=0
    print_step "running" "Starting Secure Enclave Daemon..."
    if [ "${SKIP_SECD:-0}" = "1" ]; then
        update_step "pending" "SecD            ${FG_YELLOW}SKIPPED${FG_RESET}  (requested via SKIP_SECD)"
    elif scripts/service-manager.sh start secd >/dev/null 2>&1; then
        update_step "success" "SecD            ${FG_GREEN}READY${FG_RESET}"
        secd_ok=1
    else
        update_step "pending" "SecD            ${FG_YELLOW}UNAVAILABLE${FG_RESET} (optional - build with: cargo build -p adapteros-secd)"
    fi

    # Start Node Agent - optional
    local node_ok=0
    print_step "running" "Starting Node Agent..."
    if [ "${SKIP_NODE:-0}" = "1" ]; then
        update_step "pending" "Node            ${FG_YELLOW}SKIPPED${FG_RESET}  (requested via SKIP_NODE)"
    elif scripts/service-manager.sh start node >/dev/null 2>&1; then
        update_step "success" "Node            ${FG_GREEN}READY${FG_RESET}"
        node_ok=1
    else
        update_step "pending" "Node            ${FG_YELLOW}UNAVAILABLE${FG_RESET} (optional - build with: cargo build -p adapteros-node)"
    fi

    # Final readiness check (unless --quick was used)
    local inference_ready=0
    if [ $backend_ok -eq 1 ] && [ $worker_ok -eq 1 ] && [ "${AOS_QUICK_BOOT:-0}" != "1" ]; then
        print_step "running" "Checking inference readiness..."
        local readyz_timeout="${AOS_READYZ_TIMEOUT:-30}"
        local readyz_waited=0
        ensure_var_dirs
        local readyz_tmp="$AOS_VAR_DIR/run/readyz-last.json"
        while [ $readyz_waited -lt "$readyz_timeout" ]; do
            print_progress_animated $readyz_waited $readyz_timeout "Checking /readyz..."
            local readyz_status
            local readyz_body=""
            readyz_status=$(curl -s -o "$readyz_tmp" -w "%{http_code}" --max-time 2 "http://localhost:$AOS_SERVER_PORT/readyz" 2>/dev/null || echo "000")
            if [ -f "$readyz_tmp" ]; then
                readyz_body="$(cat "$readyz_tmp")"
            fi
            log_readyz_timeline "$readyz_status" "$readyz_body"
            if [ "$readyz_status" = "200" ]; then
                term_clear_row
                update_step "success" "Inference       ${FG_GREEN}READY${FG_RESET}  (/readyz check passed)"
                inference_ready=1
                break
            fi
            sleep 1
            ((readyz_waited++))
        done
        term_clear_row
        if [ $inference_ready -eq 0 ]; then
            update_step "error" "Inference       ${FG_RED}NOT READY${FG_RESET} (/readyz timeout after ${readyz_timeout}s)"
            echo ""
            echo -e "  ${FG_RED}Inference readiness check failed.${FG_RESET} Common fixes:"
            echo "    - Seed models: aosctl models seed --model-path \$AOS_MODEL_PATH"
            echo "    - Check status: curl http://localhost:$AOS_SERVER_PORT/readyz | jq"
            echo ""
            return 1
        fi
    fi

    # Optional chat verification
    if [ "${AOS_VERIFY_CHAT:-0}" = "1" ]; then
        if [ $backend_ok -ne 1 ] || [ $worker_ok -ne 1 ]; then
            update_step "error" "Chat verification requires backend + worker"
            log_line ERROR "chat:verify blocked backend=$backend_ok worker=$worker_ok"
            return 1
        fi

        print_step "running" "Verifying chat response..."
        if ! verify_chat; then
            update_step "error" "Chat verification failed"
            return 1
        fi
        update_step "success" "Chat verification passed"
    fi

    echo ""

    # Only show full success if inference is ready (or readiness check was skipped)
    local show_full_success=0
    if [ $inference_ready -eq 1 ]; then
        show_full_success=1
    elif [ "${AOS_QUICK_BOOT:-0}" = "1" ]; then
        # Quick boot skips /readyz check, allow success message
        show_full_success=1
    elif [ "${SKIP_WORKER:-0}" = "1" ]; then
        # Worker was explicitly skipped (--skip-worker), readiness check not applicable
        show_full_success=1
    fi

    if [ $backend_ok -eq 1 ] && [ $show_full_success -eq 1 ]; then
        # Boot complete - clear the flag so cleanup won't kill services
        BOOT_IN_PROGRESS=0
        echo ""
        echo -e "${FG_GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        echo ""
        echo -e "  ${FG_GREEN}${CHECK_MARK} adapterOS is ready!${FG_RESET}"
        echo ""
        echo "  API: http://localhost:$AOS_SERVER_PORT"
        echo "  UI:  http://localhost:$AOS_SERVER_PORT  (served from static/)"
        if [ $worker_ok -eq 1 ]; then
            echo "  Worker: ${FG_GREEN}Ready${FG_RESET} (socket: $AOS_VAR_DIR/run/worker.sock)"
        else
            echo "  Worker: ${FG_YELLOW}Skipped${FG_RESET}"
        fi
        echo ""
        echo -e "${FG_GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        log_line INFO "startup:complete backend=ok worker=$worker_ok"
    else
        echo -e "${FG_RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        echo ""
        echo -e "  ${FG_RED}${CROSS_MARK} Startup failed${FG_RESET}"
        echo ""
        echo "  Check logs: var/logs/"
        echo ""
        echo -e "${FG_RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        log_line ERROR "startup:failed backend=$backend_ok worker=$worker_ok"
        return 1
    fi

    echo ""

    # Offer aosctl installation
    check_aosctl_installation
}

verify_chat() {
    local base_url="http://localhost:$AOS_SERVER_PORT"
    local chat_url="${base_url}/v1/chat/completions"
    local payload='{"messages":[{"role":"user","content":"Hello from boot verification."}],"max_tokens":16}'
    local tmp
    tmp=$(mktemp)

    local auth_header=""
    if [ -n "${AOS_AUTH_TOKEN:-}" ]; then
        auth_header="Authorization: Bearer ${AOS_AUTH_TOKEN}"
    elif [ -n "${AOS_TOKEN:-}" ]; then
        auth_header="Authorization: Bearer ${AOS_TOKEN}"
    fi

    local status="000"
    if [ -n "$auth_header" ]; then
        status=$(curl -s -o "$tmp" -w "%{http_code}" --max-time 10 \
            -H "Content-Type: application/json" -H "$auth_header" \
            -d "$payload" "$chat_url" 2>/dev/null || echo "000")
    else
        status=$(curl -s -o "$tmp" -w "%{http_code}" --max-time 10 \
            -H "Content-Type: application/json" \
            -d "$payload" "$chat_url" 2>/dev/null || echo "000")
    fi

    local body=""
    if [ -f "$tmp" ]; then
        body="$(cat "$tmp")"
        rm -f "$tmp"
    fi

    if [ "$status" != "200" ]; then
        log_line ERROR "chat:verify failed status=$status"
        echo ""
        echo -e "  ${FG_RED}Chat verification failed.${FG_RESET} HTTP $status"
        if [ -z "$auth_header" ]; then
            echo "  Hint: set AOS_AUTH_TOKEN (or AOS_TOKEN) or run with AOS_DEV_NO_AUTH=1"
        fi
        echo ""
        return 1
    fi

    if [ -z "$(printf '%s' "$body" | tr -d '[:space:]')" ]; then
        log_line ERROR "chat:verify empty_response"
        echo ""
        echo -e "  ${FG_RED}Chat verification failed.${FG_RESET} Empty response body"
        echo ""
        return 1
    fi

    log_line INFO "chat:verify ok"
    return 0
}

do_shutdown() {
    print_banner

    echo -e "${FG_CYAN}Stopping adapterOS${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    if [ -x scripts/service-manager.sh ]; then
        scripts/service-manager.sh stop-all
    else
        fg_error "service-manager.sh not found"
        return 1
    fi

    echo ""
    echo -e "${FG_GREEN}${CHECK_MARK} Shutdown complete${FG_RESET}"
    echo ""
}

# =============================================================================
# Signal Handling & Cleanup
# =============================================================================

# Track if we're in the middle of boot for cleanup
BOOT_IN_PROGRESS=0
CLEANUP_CALLED=0

# Cleanup function for graceful shutdown on signals
cleanup() {
    # Prevent recursive cleanup calls
    if [ "$CLEANUP_CALLED" -eq 1 ]; then
        return
    fi
    CLEANUP_CALLED=1

    echo ""
    log_line WARN "signal:cleanup received interrupt signal"

    # Stop spinner if running
    stop_spinner

    # Clear progress line
    term_clear_row

    if [ "$BOOT_IN_PROGRESS" -eq 1 ]; then
        echo ""
        echo -e "${FG_YELLOW}Boot interrupted. Cleaning up...${FG_RESET}"
        echo ""

        # Stop services gracefully
        if [ -x scripts/service-manager.sh ]; then
            print_step "running" "Stopping backend..."
            scripts/service-manager.sh stop backend >/dev/null 2>&1 || true
            update_step "success" "Backend stopped"

            print_step "running" "Stopping worker..."
            scripts/service-manager.sh stop worker >/dev/null 2>&1 || true
            update_step "success" "Worker stopped"
        fi

        echo ""
        echo -e "${FG_YELLOW}Cleanup complete. Exiting.${FG_RESET}"
    fi

    # Exit with error code indicating signal
    exit 130
}

# Install signal handlers
trap cleanup SIGINT SIGTERM

# =============================================================================
# Main
# =============================================================================

main() {
    ensure_var_dirs

    # Parse worker-related flags and strip them from positional args
    local parsed_args=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --worker-backend)
                if [ -n "${2:-}" ]; then
                    export AOS_MODEL_BACKEND="$2"
                    shift
                fi
                ;;
            --worker-backend=*)
                export AOS_MODEL_BACKEND="${1#*=}"
                ;;
            --worker-manifest)
                if [ -n "${2:-}" ]; then
                    export AOS_WORKER_MANIFEST="$2"
                    shift
                fi
                ;;
            --worker-manifest=*)
                export AOS_WORKER_MANIFEST="${1#*=}"
                ;;
            --worker-model|--worker-model-path)
                if [ -n "${2:-}" ]; then
                    export AOS_MODEL_PATH="$2"
                    shift
                fi
                ;;
            --worker-model=*|--worker-model-path=*)
                export AOS_MODEL_PATH="${1#*=}"
                ;;
            --worker-tokenizer)
                if [ -n "${2:-}" ]; then
                    export AOS_TOKENIZER_PATH="$2"
                    shift
                fi
                ;;
            --worker-tokenizer=*)
                export AOS_TOKENIZER_PATH="${1#*=}"
                ;;
            --skip-worker|--no-worker)
                SKIP_WORKER=1
                ;;
            --quick)
                AOS_QUICK_BOOT=1
                ;;
            --verify-chat)
                AOS_VERIFY_CHAT=1
                ;;
            --verbose)
                VERBOSE=1
                export AOS_BOOT_VERBOSE=1
                ;;
            --trace)
                TRACE=1
                VERBOSE=1
                export AOS_BOOT_VERBOSE=1
                export AOS_LOG_PROFILE="trace"
                ;;
            --)
                shift
                break
                ;;
            *)
                parsed_args+=("$1")
                ;;
        esac
        shift
    done

    while [ $# -gt 0 ]; do
        parsed_args+=("$1")
        shift
    done

    set -- "${parsed_args[@]}"

    # If verbose/trace is enabled, output may include streaming logs (e.g. tail -F).
    # Disable in-place animations to avoid cursor corruption and scrolling jitter.
    if [ "${VERBOSE:-0}" -eq 1 ] || [ "${TRACE:-0}" -eq 1 ]; then
        AOS_CAN_ANIMATE=0
    fi

    local cmd="${1:-up}"

    case "$cmd" in
        up|start|"")
            check_start_dependencies "up"
            run_dev_log_hygiene
            start_all
            ;;
        down|stop)
            do_shutdown
            ;;
        status)
            show_status
            ;;
        backend)
            check_start_dependencies "backend"
            run_dev_log_hygiene
            start_backend
            ;;
        worker)
            check_start_dependencies "worker"
            run_dev_log_hygiene
            if [ -x scripts/service-manager.sh ]; then
                scripts/service-manager.sh start worker
            else
                fg_error "service-manager.sh not found"
                exit 1
            fi
            ;;
        secd)
            check_start_dependencies "secd"
            run_dev_log_hygiene
            if [ -x scripts/service-manager.sh ]; then
                scripts/service-manager.sh start secd
            else
                fg_error "service-manager.sh not found"
                exit 1
            fi
            ;;
        node)
            check_start_dependencies "node"
            run_dev_log_hygiene
            if [ -x scripts/service-manager.sh ]; then
                scripts/service-manager.sh start node
            else
                fg_error "service-manager.sh not found"
                exit 1
            fi
            ;;
        init)
            source scripts/lib/manifest-wizard.sh
            shift
            run_manifest_wizard "$@"
            ;;
        preflight|check)
            print_banner
            echo -e "${FG_CYAN}Preflight Checks${FG_RESET}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            do_preflight
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            fg_error "Unknown command: $cmd"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
