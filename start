do_shutdown() {
    print_banner

    echo -e "${FG_CYAN}Stopping AdapterOS${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    if [ -x scripts/service-manager.sh ]; then
        # Get current PIDs before stopping
        local backend_pid=""
        local ui_pid=""

        if [ -f "$AOS_VAR_DIR/backend.pid" ]; then
            backend_pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
        fi
        if [ -f "$AOS_VAR_DIR/ui.pid" ]; then
            ui_pid=$(cat "$AOS_VAR_DIR/ui.pid" 2>/dev/null)
        fi

        # Stop UI first
        if [ -n "$ui_pid" ] && kill -0 "$ui_pid" 2>/dev/null; then
            print_step "running" "Stopping UI Server (PID $ui_pid)..."
            scripts/service-manager.sh stop ui >/dev/null 2>&1 || true

            # Wait for stop
            local waited=0
            while kill -0 "$ui_pid" 2>/dev/null && [ $waited -lt 10 ]; do
                sleep 1
                ((waited++))
            done

            if ! kill -0 "$ui_pid" 2>/dev/null; then
                update_step "success" "UI Server stopped"
            else
                update_step "error" "UI Server did not stop cleanly"
            fi
        else
            print_step "pending" "UI Server       (not running)"
        fi

        # Stop backend
        if [ -n "$backend_pid" ] && kill -0 "$backend_pid" 2>/dev/null; then
            print_step "running" "Stopping Backend API (PID $backend_pid)..."
            scripts/service-manager.sh stop backend >/dev/null 2>&1 || true

            # Wait for stop
            local waited=0
            while kill -0 "$backend_pid" 2>/dev/null && [ $waited -lt 15 ]; do
                sleep 1
                ((waited++))
            done

            if ! kill -0 "$backend_pid" 2>/dev/null; then
                update_step "success" "Backend API stopped"
            else
                update_step "error" "Backend API did not stop cleanly"
            fi
        else
            print_step "pending" "Backend API     (not running)"
        fi
    else
        fg_error "service-manager.sh not found"
        return 1
    fi

    echo ""
    echo -e "${FG_GREEN}${CHECK_MARK} Shutdown complete${FG_RESET}"
    echo ""
}

# =============================================================================
# Main
# =============================================================================

main() {
    # Parse worker-related flags and strip them from positional args
    local parsed_args=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --worker-backend)
                if [ -n "${2:-}" ]; then
                    export AOS_MODEL_BACKEND="$2"
                    shift
                fi
                ;;
            --worker-backend=*)
                export AOS_MODEL_BACKEND="${1#*=}"
                ;;
            --worker-manifest)
                if [ -n "${2:-}" ]; then
                    export AOS_WORKER_MANIFEST="$2"
                    shift
                fi
                ;;
            --worker-manifest=*)
                export AOS_WORKER_MANIFEST="${1#*=}"
                ;;
            --worker-model|--worker-model-path)
                if [ -n "${2:-}" ]; then
                    export AOS_MODEL_PATH="$2"
                    shift
                fi
                ;;
            --worker-model=*|--worker-model-path=*)
                export AOS_MODEL_PATH="${1#*=}"
                ;;
            --worker-tokenizer)
                if [ -n "${2:-}" ]; then
                    export AOS_TOKENIZER_PATH="$2"
                    shift
                fi
                ;;
            --worker-tokenizer=*)
                export AOS_TOKENIZER_PATH="${1#*=}"
                ;;
            --skip-worker|--no-worker)
                SKIP_WORKER=1
                ;;
            --quick)
                AOS_QUICK_BOOT=1
                ;;
            --)
                shift
                break
                ;;
            *)
                parsed_args+=("$1")
                ;;
        esac
        shift
    done

    while [ $# -gt 0 ]; do
        parsed_args+=("$1")
        shift
    done

    set -- "${parsed_args[@]}"

    local cmd="${1:-up}"

    case "$cmd" in
        up|start|"")
            start_all
            ;;
        down|stop)
            do_shutdown
            ;;
        status)
            show_status
            ;;
        backend)
            start_backend
            ;;
        preflight|check)
            print_banner
            echo -e "${FG_CYAN}Preflight Checks${FG_RESET}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            do_preflight
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            fg_error "Unknown command: $cmd"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
