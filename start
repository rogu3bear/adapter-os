show_status() {
    echo ""
    echo -e "${FG_CYAN}AdapterOS Service Status${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Check backend
    local backend_pid_file="$AOS_VAR_DIR/backend.pid"
    local backend_status="stopped"
    local backend_pid=""

    if [ -f "$backend_pid_file" ]; then
        backend_pid=$(cat "$backend_pid_file" 2>/dev/null)
        if [ -n "$backend_pid" ] && kill -0 "$backend_pid" 2>/dev/null; then
            backend_status="running"
        fi
    else
        backend_pid=$(lsof -nP -i :"$AOS_SERVER_PORT" -sTCP:LISTEN -t 2>/dev/null | head -1)
        if [ -n "$backend_pid" ]; then
            backend_status="running"
        fi
    fi

    if [ "$backend_status" = "running" ]; then
        # Check if health endpoint responds
        if curl -sf "http://localhost:$AOS_SERVER_PORT/healthz" >/dev/null 2>&1; then
            print_step "success" "Backend API     ${FG_GREEN}HEALTHY${FG_RESET}  (PID $backend_pid, port $AOS_SERVER_PORT)"
        else
            print_step "running" "Backend API     ${FG_YELLOW}STARTING${FG_RESET} (PID $backend_pid, port $AOS_SERVER_PORT)"
        fi
    else
        print_step "error" "Backend API     ${FG_RED}STOPPED${FG_RESET}"
    fi

    # Check UI
    local ui_pid_file="$AOS_VAR_DIR/ui.pid"
    local ui_status="stopped"
    local ui_pid=""

    if [ -f "$ui_pid_file" ]; then
        ui_pid=$(cat "$ui_pid_file" 2>/dev/null)
        if [ -n "$ui_pid" ] && kill -0 "$ui_pid" 2>/dev/null; then
            ui_status="running"
        fi
    else
        ui_pid=$(lsof -nP -i :"$AOS_UI_PORT" -sTCP:LISTEN -t 2>/dev/null | head -1)
        if [ -n "$ui_pid" ]; then
            ui_status="running"
        fi
    fi

    if [ "$ui_status" = "running" ]; then
        if curl -sf "http://localhost:$AOS_UI_PORT" >/dev/null 2>&1; then
            print_step "success" "UI Server       ${FG_GREEN}HEALTHY${FG_RESET}  (PID $ui_pid, port $AOS_UI_PORT)"
        else
            print_step "running" "UI Server       ${FG_YELLOW}STARTING${FG_RESET} (PID $ui_pid, port $AOS_UI_PORT)"
        fi
    else
        print_step "error" "UI Server       ${FG_RED}STOPPED${FG_RESET}"
    fi

    # Check worker
    local worker_sock="$AOS_VAR_DIR/run/worker.sock"
    local worker_pid_file="$AOS_VAR_DIR/worker.pid"
    if [ -S "$worker_sock" ] && lsof "$worker_sock" >/dev/null 2>&1; then
        local worker_pid
        worker_pid=$(lsof -t "$worker_sock" 2>/dev/null | head -1)
        if [ -n "$worker_pid" ] && kill -0 "$worker_pid" 2>/dev/null; then
            print_step "success" "Worker          ${FG_GREEN}RUNNING${FG_RESET}  (PID $worker_pid, socket)"
        else
            print_step "error" "Worker          ${FG_RED}STALE${FG_RESET}    (socket exists but process dead)"
        fi
    elif [ -f "$worker_pid_file" ]; then
        local worker_pid
        worker_pid=$(cat "$worker_pid_file" 2>/dev/null)
        if [ -n "$worker_pid" ] && kill -0 "$worker_pid" 2>/dev/null; then
            print_step "running" "Worker          ${FG_YELLOW}STARTING${FG_RESET} (PID $worker_pid, socket pending)"
        else
            print_step "error" "Worker          ${FG_RED}STOPPED${FG_RESET}  (stale PID file)"
        fi
    else
        print_step "pending" "Worker          ${FG_YELLOW}STOPPED${FG_RESET}  (optional)"
    fi

    echo ""

    # Database info
    local db_path="$AOS_VAR_DIR/aos-cp.sqlite3"
    if [ -f "$db_path" ]; then
        local size
        size=$(du -h "$db_path" 2>/dev/null | cut -f1)
        echo "  Database: $db_path ($size)"
    else
        echo "  Database: Not initialized"
    fi

    echo ""

    # Show URLs if running
    if [ "$backend_status" = "running" ] || [ "$ui_status" = "running" ]; then
        echo -e "${FG_CYAN}Access URLs:${FG_RESET}"
        if [ "$backend_status" = "running" ]; then
            echo "  API:  http://localhost:$AOS_SERVER_PORT"
        fi
        if [ "$ui_status" = "running" ]; then
            echo "  UI:   http://localhost:$AOS_UI_PORT"
        fi
        echo ""
    fi
}

do_preflight() {
    freeze_preflight "$AOS_SERVER_PORT" "$AOS_UI_PORT" "$AOS_VAR_DIR"
}

# Start backend with progress animation
start_backend_animated() {
    print_step "running" "Starting Backend API..."
    log_line INFO "backend:start requested (port=$AOS_SERVER_PORT verbose=$VERBOSE trace=$TRACE)"

    ensure_var_dirs

    # Run preflight silently
    if ! freeze_check_port "$AOS_SERVER_PORT" "Backend API" 2>/dev/null; then
        update_step "error" "Backend API - port $AOS_SERVER_PORT in use"
        log_line ERROR "backend:start blocked (port-in-use $AOS_SERVER_PORT)"
        return 1
    fi

    # Delegate to service-manager
    if [ -x scripts/service-manager.sh ]; then
        local tail_pid=""
        if scripts/service-manager.sh start-backend >/dev/null 2>&1; then
            if [ $VERBOSE -eq 1 ] || [ $TRACE -eq 1 ]; then
                touch "$AOS_LOG_DIR/backend.log"
                tail -n 20 -F "$AOS_LOG_DIR/backend.log" &
                tail_pid=$!
            fi
            # Wait for health check (configurable timeout)
            local waited=0
            local health_timeout="${AOS_HEALTH_TIMEOUT:-15}"
            while [ $waited -lt "$health_timeout" ]; do
                if curl -sf --max-time 2 "http://localhost:$AOS_SERVER_PORT/healthz" >/dev/null 2>&1; then
                    local pid
                    pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
                    update_step "success" "Backend API     ${FG_GREEN}READY${FG_RESET}  (PID $pid, port $AOS_SERVER_PORT)"
                    log_line INFO "backend:ready pid=$pid port=$AOS_SERVER_PORT"
                    if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
                    #region agent log
                    append_debug_log \
                        "start_backend_animated:health" \
                        "backend ready" \
                        "H1" \
                        "$(printf '{"pid":"%s","manifest":"%s","backend_port":"%s"}' "$pid" "${AOS_MANIFEST_PATH:-}" "${AOS_SERVER_PORT:-8080}")"
                    #endregion agent log
                    return 0
                fi
                sleep 1
                ((waited++))
            done
            # Health check timeout - this is a failure, not success
            local pid
            pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
            local health_timeout="${AOS_HEALTH_TIMEOUT:-15}"
            if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                update_step "error" "Backend API     ${FG_RED}UNHEALTHY${FG_RESET} (PID $pid, healthz timeout after ${health_timeout}s)"
            else
                update_step "error" "Backend API     ${FG_RED}CRASHED${FG_RESET} (process not running)"
            fi
            log_line ERROR "backend:health_timeout pid=${pid:-none} timeout=${health_timeout}s"
            [ "${AOS_BOOT_VERBOSE:-0}" = "1" ] && tail -20 "$AOS_VAR_DIR/logs/backend.log" 2>/dev/null
            #region agent log
            append_debug_log \
                "start_backend_animated:health_timeout" \
                "backend healthz timeout - treated as failure" \
                "H1" \
                "$(printf '{"pid":"%s","manifest":"%s","backend_port":"%s"}' "$pid" "${AOS_MANIFEST_PATH:-}" "${AOS_SERVER_PORT:-8080}")"
            #endregion agent log
            if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
            return 1
        else
            update_step "error" "Backend API - failed to start"
            log_line ERROR "backend:start failed (service-manager start-backend)"
            #region agent log
            append_debug_log \
                "start_backend_animated:error" \
                "backend start failed" \
                "H1" \
                "$(printf '{"manifest":"%s","backend_port":"%s"}' "${AOS_MANIFEST_PATH:-}" "${AOS_SERVER_PORT:-8080}")"
            #endregion agent log
            return 1
        fi
    else
        update_step "error" "Backend API - service-manager.sh not found"
        return 1
    fi
}

# Start UI with progress animation
start_ui_animated() {
    print_step "running" "Starting UI Server..."
    log_line INFO "ui:start requested (port=$AOS_UI_PORT verbose=$VERBOSE trace=$TRACE)"

    # Delegate to service-manager
    if [ -x scripts/service-manager.sh ]; then
        local tail_pid=""
        if scripts/service-manager.sh start ui >/dev/null 2>&1; then
            if [ $VERBOSE -eq 1 ] || [ $TRACE -eq 1 ]; then
                touch "$AOS_LOG_DIR/ui.log"
                tail -n 20 -F "$AOS_LOG_DIR/ui.log" &
                tail_pid=$!
            fi
            # Wait for response
            local waited=0
            while [ $waited -lt 20 ]; do
                if curl -sf "http://localhost:$AOS_UI_PORT" >/dev/null 2>&1; then
                    local pid
                    pid=$(cat "$AOS_VAR_DIR/ui.pid" 2>/dev/null)
                    update_step "success" "UI Server       ${FG_GREEN}READY${FG_RESET}  (PID $pid, port $AOS_UI_PORT)"
                    log_line INFO "ui:ready pid=$pid port=$AOS_UI_PORT"
                    if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
                    #region agent log
                    append_debug_log \
                        "start_ui_animated:ready" \
                        "ui ready" \
                        "H2" \
                        "$(printf '{"pid":"%s","ui_port":"%s"}' "$pid" "${AOS_UI_PORT:-3200}")"
                    #endregion agent log
                    return 0
                fi
                sleep 1
                ((waited++))
            done
            # Started but not responding yet
            local pid
            pid=$(cat "$AOS_VAR_DIR/ui.pid" 2>/dev/null)
            update_step "success" "UI Server       ${FG_YELLOW}STARTED${FG_RESET} (PID $pid, port $AOS_UI_PORT)"
            log_line WARN "ui:started_without_ready pid=${pid:-none} port=$AOS_UI_PORT"
            if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
            #region agent log
            append_debug_log \
                "start_ui_animated:started" \
                "ui started without readiness" \
                "H2" \
                "$(printf '{"pid":"%s","ui_port":"%s"}' "$pid" "${AOS_UI_PORT:-3200}")"
            #endregion agent log
            return 0
        else
            update_step "error" "UI Server - failed to start"
            #region agent log
            append_debug_log \
                "start_ui_animated:error" \
                "ui start failed" \
                "H2" \
                "$(printf '{"ui_port":"%s"}' "${AOS_UI_PORT:-3200}")"
            #endregion agent log
            return 1
        fi
    else
        update_step "error" "UI Server - service-manager.sh not found"
        log_line ERROR "ui:start failed (service-manager missing)"
        return 1
    fi
}

start_backend() {
    print_banner

    echo -e "${FG_CYAN}Starting Backend${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    ensure_var_dirs
    dump_env_summary
    check_stale_artifacts

    # Preflight
    print_step "running" "Running preflight checks..."
    if ! freeze_check_port "$AOS_SERVER_PORT" "Backend API"; then
        update_step "error" "Preflight failed"
        return 1
    fi
    if ! freeze_check_pid_file "$AOS_VAR_DIR/backend.pid" "Backend"; then
        update_step "error" "Preflight failed"
        return 1
    fi
    update_step "success" "Preflight checks passed"

    # Start
    start_backend_animated

    echo ""
    echo -e "${FG_GREEN}Backend ready!${FG_RESET}"
    echo ""
    echo "  API: http://localhost:$AOS_SERVER_PORT"
    echo ""

    # Offer aosctl installation
    check_aosctl_installation
}

start_all() {
    print_banner

    echo -e "${FG_CYAN}Starting AdapterOS${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    ensure_var_dirs

    #region agent log
    append_debug_log \
        "start_all:env" \
        "start_all entry" \
        "H4" \
        "$(printf '{"AOS_SERVER_PORT":"%s","AOS_UI_PORT":"%s","AOS_MANIFEST_PATH":"%s","AOS_MODEL_BACKEND":"%s","SKIP_WORKER":"%s"}' "${AOS_SERVER_PORT:-8080}" "${AOS_UI_PORT:-3200}" "${AOS_MANIFEST_PATH:-}" "${AOS_MODEL_BACKEND:-}" "${SKIP_WORKER:-0}")"
    #endregion agent log

    # Preflight with animation
    print_step "running" "Running preflight checks..."
    log_line INFO "preflight:start"

    local preflight_failed=0

    # Port checks
    if ! freeze_check_port "$AOS_SERVER_PORT" "Backend API"; then
        preflight_failed=1
        log_line WARN "preflight:backend_port_busy port=$AOS_SERVER_PORT"
    fi

    if ! freeze_check_port "$AOS_UI_PORT" "UI Server"; then
        preflight_failed=1
        log_line WARN "preflight:ui_port_busy port=$AOS_UI_PORT"
    fi

    log_line INFO "preflight:complete status=$preflight_failed"

    if [ $preflight_failed -eq 1 ]; then
        update_step "error" "Preflight checks failed (see above)"
        echo ""
        echo "  Run ${FG_CYAN}./start preflight${FG_RESET} for details"
        return 1
    fi

    update_step "success" "Preflight checks passed"
    echo ""

    # Start services
    local backend_ok=0
    local ui_ok=0
    local worker_ok=0

    start_backend_animated && backend_ok=1
    start_ui_animated && ui_ok=1

    # Seed model into database if AOS_MODEL_PATH is set
    if [ $backend_ok -eq 1 ] && [ -n "${AOS_MODEL_PATH:-}" ]; then
        print_step "running" "Seeding model into database..."
        local aosctl_bin=""
        if [ -f "./aosctl" ]; then
            aosctl_bin="./aosctl"
        elif [ -f "target/debug/aosctl" ]; then
            aosctl_bin="target/debug/aosctl"
        elif [ -f "target/release/aosctl" ]; then
            aosctl_bin="target/release/aosctl"
        fi

        if [ -n "$aosctl_bin" ]; then
            if "$aosctl_bin" models seed --model-path "$AOS_MODEL_PATH" >/dev/null 2>&1; then
                update_step "success" "Model seeded"
            else
                update_step "pending" "Model seeding  ${FG_YELLOW}SKIPPED${FG_RESET}  (already exists or error)"
            fi
        else
            update_step "pending" "Model seeding  ${FG_YELLOW}SKIPPED${FG_RESET}  (aosctl not found)"
        fi
    fi

    # Start worker (required by default, use --skip-worker to opt out)
    print_step "running" "Starting Inference Worker..."
    if [ "${SKIP_WORKER:-0}" = "1" ]; then
        update_step "pending" "Worker          ${FG_YELLOW}SKIPPED${FG_RESET}  (requested via --skip-worker)"
    elif scripts/service-manager.sh start worker >/dev/null 2>&1; then
        # Wait for socket
        local waited=0
        while [ $waited -lt 15 ]; do
            if [ -S "$AOS_VAR_DIR/run/worker.sock" ]; then
                update_step "success" "Worker          ${FG_GREEN}READY${FG_RESET}  (socket created)"
                worker_ok=1
                break
            fi
            sleep 1
            ((waited++))
        done
        if [ $worker_ok -eq 0 ]; then
            update_step "pending" "Worker          ${FG_YELLOW}STARTING${FG_RESET} (socket pending)"
        fi
    else
        update_step "error" "Worker          ${FG_RED}FAILED${FG_RESET}  - inference not available"
        echo ""
        echo -e "  ${FG_RED}Worker startup failed.${FG_RESET} Possible causes:"
        echo "    - Worker binary not built: cargo build -p adapteros-lora-worker"
        echo "    - Manifest not found: set AOS_WORKER_MANIFEST"
        echo "    - Model not found: set AOS_MODEL_PATH"
        echo ""
        echo -e "  To run without worker (UI-only mode): ${FG_CYAN}./start --skip-worker${FG_RESET}"
        echo ""
        return 1
    fi

    #region agent log
    append_debug_log \
        "start_all:worker" \
        "worker start result" \
        "H3" \
        "$(printf '{"skip_worker":"%s","worker_socket_exists":%s,"worker_ok":%s}' \
            "${SKIP_WORKER:-0}" \
            "$( [ -S \"$AOS_VAR_DIR/run/worker.sock\" ] && echo true || echo false )" \
            "$( [ "$worker_ok" -eq 1 ] && echo true || echo false )" \
        )"
    #endregion agent log

    # Final readiness check (unless --quick was used)
    local inference_ready=0
    if [ $backend_ok -eq 1 ] && [ $worker_ok -eq 1 ] && [ "${AOS_QUICK_BOOT:-0}" != "1" ]; then
        print_step "running" "Checking inference readiness..."
        local readyz_timeout="${AOS_READYZ_TIMEOUT:-30}"
        local readyz_waited=0
        ensure_var_dirs
        local readyz_tmp="$AOS_VAR_DIR/run/readyz-last.json"
        while [ $readyz_waited -lt "$readyz_timeout" ]; do
            local readyz_status
            local readyz_body=""
            readyz_status=$(curl -s -o "$readyz_tmp" -w "%{http_code}" --max-time 2 "http://localhost:$AOS_SERVER_PORT/readyz" 2>/dev/null || echo "000")
            if [ -f "$readyz_tmp" ]; then
                readyz_body="$(cat "$readyz_tmp")"
            fi
            log_readyz_timeline "$readyz_status" "$readyz_body"
            if [ "$readyz_status" = "200" ]; then
                update_step "success" "Inference       ${FG_GREEN}READY${FG_RESET}  (/readyz check passed)"
                inference_ready=1
                break
            fi
            sleep 1
            ((readyz_waited++))
        done
        if [ $inference_ready -eq 0 ]; then
            update_step "error" "Inference       ${FG_RED}NOT READY${FG_RESET} (/readyz timeout after ${readyz_timeout}s)"
            echo ""
            echo -e "  ${FG_RED}Inference readiness check failed.${FG_RESET} Common fixes:"
            echo "    - Seed models: aosctl models seed --model-path \$AOS_MODEL_PATH"
            echo "    - Check status: curl http://localhost:$AOS_SERVER_PORT/readyz | jq"
            echo ""
            return 1
        fi
    fi

    echo ""

    # Only show full success if inference is ready (or readiness check was skipped)
    local show_full_success=0
    if [ $inference_ready -eq 1 ]; then
        show_full_success=1
    elif [ "${AOS_QUICK_BOOT:-0}" = "1" ]; then
        # Quick boot skips /readyz check, allow success message
        show_full_success=1
    elif [ $worker_ok -eq 0 ]; then
        # Worker was skipped (--skip-worker), readiness check not applicable
        show_full_success=1
    fi

    if [ $backend_ok -eq 1 ] && [ $ui_ok -eq 1 ] && [ $show_full_success -eq 1 ]; then
        echo -e "${FG_GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        echo ""
        echo -e "  ${FG_GREEN}${CHECK_MARK} AdapterOS is ready!${FG_RESET}"
        echo ""
        echo "  API: http://localhost:$AOS_SERVER_PORT"
        echo "  UI:  http://localhost:$AOS_UI_PORT"
        if [ $worker_ok -eq 1 ]; then
            echo "  Worker: ${FG_GREEN}Ready${FG_RESET} (socket: $AOS_VAR_DIR/run/worker.sock)"
        else
            echo "  Worker: ${FG_YELLOW}Optional${FG_RESET} (not started)"
        fi
        echo ""
        echo -e "${FG_GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        log_line INFO "startup:complete backend=ok ui=ok worker=$worker_ok"
    elif [ $backend_ok -eq 1 ]; then
        echo -e "${FG_YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        echo ""
        echo -e "  ${FG_YELLOW}Backend started, UI failed${FG_RESET}"
        echo ""
        echo "  API: http://localhost:$AOS_SERVER_PORT"
        echo ""
        echo -e "${FG_YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        log_line WARN "startup:partial backend=ok ui=fail worker=$worker_ok"
    else
        echo -e "${FG_RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        echo ""
        echo -e "  ${FG_RED}${CROSS_MARK} Startup failed${FG_RESET}"
        echo ""
        echo "  Check logs: var/logs/"
        echo ""
        echo -e "${FG_RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
        log_line ERROR "startup:failed backend=$backend_ok ui=$ui_ok worker=$worker_ok"
        return 1
    fi

    echo ""

    # Offer aosctl installation
    check_aosctl_installation
}

do_shutdown() {
    print_banner

    echo -e "${FG_CYAN}Stopping AdapterOS${FG_RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    if [ -x scripts/service-manager.sh ]; then
        # Get current PIDs before stopping
        local backend_pid=""
        local ui_pid=""

        if [ -f "$AOS_VAR_DIR/backend.pid" ]; then
            backend_pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
        fi
        if [ -f "$AOS_VAR_DIR/ui.pid" ]; then
            ui_pid=$(cat "$AOS_VAR_DIR/ui.pid" 2>/dev/null)
        fi

        # Stop UI first
        if [ -n "$ui_pid" ] && kill -0 "$ui_pid" 2>/dev/null; then
            print_step "running" "Stopping UI Server (PID $ui_pid)..."
            scripts/service-manager.sh stop ui >/dev/null 2>&1 || true

            # Wait for stop
            local waited=0
            while kill -0 "$ui_pid" 2>/dev/null && [ $waited -lt 10 ]; do
                sleep 1
                ((waited++))
            done

            if ! kill -0 "$ui_pid" 2>/dev/null; then
                update_step "success" "UI Server stopped"
            else
                update_step "error" "UI Server did not stop cleanly"
            fi
        else
            print_step "pending" "UI Server       (not running)"
        fi

        # Stop backend
        if [ -n "$backend_pid" ] && kill -0 "$backend_pid" 2>/dev/null; then
            print_step "running" "Stopping Backend API (PID $backend_pid)..."
            scripts/service-manager.sh stop backend >/dev/null 2>&1 || true

            # Wait for stop
            local waited=0
            while kill -0 "$backend_pid" 2>/dev/null && [ $waited -lt 15 ]; do
                sleep 1
                ((waited++))
            done

            if ! kill -0 "$backend_pid" 2>/dev/null; then
                update_step "success" "Backend API stopped"
            else
                update_step "error" "Backend API did not stop cleanly"
            fi
        else
            print_step "pending" "Backend API     (not running)"
        fi
    else
        fg_error "service-manager.sh not found"
        return 1
    fi

    echo ""
    echo -e "${FG_GREEN}${CHECK_MARK} Shutdown complete${FG_RESET}"
    echo ""
}

# =============================================================================
# Main
# =============================================================================

main() {
    # Parse worker-related flags and strip them from positional args
    local parsed_args=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --worker-backend)
                if [ -n "${2:-}" ]; then
                    export AOS_MODEL_BACKEND="$2"
                    shift
                fi
                ;;
            --worker-backend=*)
                export AOS_MODEL_BACKEND="${1#*=}"
                ;;
            --worker-manifest)
                if [ -n "${2:-}" ]; then
                    export AOS_WORKER_MANIFEST="$2"
                    shift
                fi
                ;;
            --worker-manifest=*)
                export AOS_WORKER_MANIFEST="${1#*=}"
                ;;
            --worker-model|--worker-model-path)
                if [ -n "${2:-}" ]; then
                    export AOS_MODEL_PATH="$2"
                    shift
                fi
                ;;
            --worker-model=*|--worker-model-path=*)
                export AOS_MODEL_PATH="${1#*=}"
                ;;
            --worker-tokenizer)
                if [ -n "${2:-}" ]; then
                    export AOS_TOKENIZER_PATH="$2"
                    shift
                fi
                ;;
            --worker-tokenizer=*)
                export AOS_TOKENIZER_PATH="${1#*=}"
                ;;
            --skip-worker|--no-worker)
                SKIP_WORKER=1
                ;;
            --quick)
                AOS_QUICK_BOOT=1
                ;;
            --verbose)
                VERBOSE=1
                export AOS_BOOT_VERBOSE=1
                ;;
            --trace)
                TRACE=1
                VERBOSE=1
                export AOS_BOOT_VERBOSE=1
                export AOS_LOG_PROFILE="trace"
                ;;
            --)
                shift
                break
                ;;
            *)
                parsed_args+=("$1")
                ;;
        esac
        shift
    done

    while [ $# -gt 0 ]; do
        parsed_args+=("$1")
        shift
    done

    set -- "${parsed_args[@]}"

    local cmd="${1:-up}"

    case "$cmd" in
        up|start|"")
            start_all
            ;;
        down|stop)
            do_shutdown
            ;;
        status)
            show_status
            ;;
        backend)
            start_backend
            ;;
        preflight|check)
            print_banner
            echo -e "${FG_CYAN}Preflight Checks${FG_RESET}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            do_preflight
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            fg_error "Unknown command: $cmd"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
