    "sessionId": "debug-session",
    "runId": os.environ.get("AOS_DEBUG_RUN_ID", "pre-fix"),
    "hypothesisId": "H1",
    "location": "start_backend_animated:health_timeout",
    "message": "backend healthz timeout - treated as failure",
    "data": {
        "pid": os.environ.get("BACKEND_PID"),
        "manifest": os.environ.get("AOS_MANIFEST_PATH"),
        "backend_port": os.environ.get("AOS_SERVER_PORT", "8080")
    },
    "timestamp": int(time.time() * 1000)
}
with open(log_path, "a") as f:
    f.write(json.dumps(payload) + "\n")
PY
            #endregion agent log
            return 1
        else
            update_step "error" "Backend API - failed to start"
            #region agent log
            python - <<'PY'
