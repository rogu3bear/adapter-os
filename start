ensure_var_dirs() {
    mkdir -p "$AOS_VAR_DIR/run"
    mkdir -p "$AOS_LOG_DIR"
    ensure_backend_log_alias
}

ensure_backend_log_alias() {
    local alias="$AOS_LOG_DIR/server.log"
    local backend="$AOS_LOG_DIR/backend.log"

    if [ -L "$alias" ]; then
        ln -sfn "backend.log" "$alias" 2>/dev/null || true
        return
    fi

    if [ -e "$alias" ]; then
        if [ ! -e "$backend" ]; then
            mv "$alias" "$backend"
        else
            local ts
            ts=$(date +%s)
            mv "$alias" "${alias}.legacy.${ts}"
        fi
    fi

    if [ ! -e "$alias" ]; then
        ln -sfn "backend.log" "$alias" 2>/dev/null || true
    fi
}

rotate_boot_logs() {
    ensure_var_dirs
    local max_bytes=2097152  # ~2MB
    for f in "$SCRIPT_LOG" "$DEBUG_LOG_PATH" "$READYZ_TIMELINE_PATH"; do
        [ -f "$f" ] || continue
        local size
        size=$(wc -c < "$f" 2>/dev/null | tr -d ' ')
        if [ -n "$size" ] && [ "$size" -gt "$max_bytes" ]; then
            mv "$f" "${f}.prev"
        fi
    done
}

run_dev_log_hygiene() {
    ensure_var_dirs

    # Rotate boot logs if they exceed ~2MB
    rotate_boot_logs

    local log_retention_days="${AOS_DEV_LOG_RETENTION_DAYS:-7}"
    local db_retention_days="${AOS_DEV_CLIENT_ERROR_RETENTION_DAYS:-30}"

    if ! [[ "$log_retention_days" =~ ^[0-9]+$ ]]; then
        log_line WARN "hygiene:invalid_log_retention '$log_retention_days' (using 7)"
        log_retention_days=7
    fi
    if ! [[ "$db_retention_days" =~ ^[0-9]+$ ]]; then
        log_line WARN "hygiene:invalid_db_retention '$db_retention_days' (using 30)"
        db_retention_days=30
    fi

    local logs_pruned=0
    if [ -d "$AOS_LOG_DIR" ]; then
        while IFS= read -r stale_log; do
            [ -z "$stale_log" ] && continue
            if rm -f "$stale_log"; then
                logs_pruned=$((logs_pruned + 1))
            fi
        done < <(
            find "$AOS_LOG_DIR" \
                -maxdepth 1 \
                -type f \
                \( \
                    -name "*.log" \
                    -o -name "*.err" \
                    -o -name "*.out" \
                    -o -name "*.json" \
                    -o -name "*.jsonl" \
                    -o -name "*.ndjson" \
                    -o -name "aos-cp.*" \
                    -o -name "aos-worker.*" \
                    -o -name "worker-demo.*" \
                \) \
                -mtime +"$log_retention_days" \
                -print 2>/dev/null || true
        )
    fi

    local client_errors_pruned="skip-no-db"
    local db_path="$AOS_VAR_DIR/aos-cp.sqlite3"
    if [ -f "$db_path" ]; then
        if command -v sqlite3 >/dev/null 2>&1; then
            local sql_output=""
            if sql_output=$(
                sqlite3 "$db_path" \
                    "DELETE FROM client_errors WHERE created_at < datetime('now', '-${db_retention_days} days'); SELECT changes();" \
                    2>/dev/null
            ); then
                client_errors_pruned="$(printf '%s\n' "$sql_output" | tail -n1 | tr -d '[:space:]')"
                [ -z "$client_errors_pruned" ] && client_errors_pruned=0
            else
                client_errors_pruned="error"
                log_line WARN "hygiene:sqlite_prune_failed db=$db_path"
            fi
        else
            client_errors_pruned="skip-no-sqlite3"
            log_line WARN "hygiene:sqlite3_missing client_errors_prune_skipped"
        fi
    fi

    log_line INFO "hygiene:retention log_days=$log_retention_days db_days=$db_retention_days logs_pruned=$logs_pruned client_errors_pruned=$client_errors_pruned"
}

now_ms() {
    # macOS `date` lacks %N, so multiply seconds to avoid Python
    echo $(( $(date +%s) * 1000 ))
}

append_debug_log() {
    local location="$1"
    local message="$2"
    local hypothesis="$3"
    local data_json="${4:-{}}"

    ensure_var_dirs
    mkdir -p "$(dirname "$DEBUG_LOG_PATH")"
    local ts_ms
    ts_ms=$(now_ms)

    if command -v jq >/dev/null 2>&1; then
        jq -nc \
            --arg session "debug-session" \
            --arg runId "${AOS_RUN_ID:-pre-fix}" \
            --arg hyp "${hypothesis:-}" \
            --arg loc "$location" \
            --arg msg "$message" \
            --argjson data "$data_json" \
            --arg ts "$ts_ms" \
            '{sessionId:$session, runId:$runId, hypothesisId:$hyp, location:$loc, message:$msg, data:$data, timestamp: ($ts|tonumber)}' \
            >>"$DEBUG_LOG_PATH" 2>/dev/null && return
    fi

    printf '{"sessionId":"%s","runId":"%s","hypothesisId":"%s","location":"%s","message":"%s","data":%s,"timestamp":%s}\n' \
        "debug-session" "${AOS_RUN_ID:-pre-fix}" "${hypothesis:-}" "$location" "$message" "${data_json:-{}}" "$ts_ms" \
        >>"$DEBUG_LOG_PATH"
}

log_line() {
    local level="$1"; shift
    local msg="$*"
    ensure_var_dirs
    local ts
    ts=$(date -Iseconds)
    local line="[$ts] [$level] [start] [$AOS_RUN_ID] $msg"
    echo -e "$line"
    echo -e "$line" >>"$SCRIPT_LOG"
}

log_readyz_timeline() {
    local status="$1"
    local body="$2"
    ensure_var_dirs
    mkdir -p "$(dirname "$READYZ_TIMELINE_PATH")"
    local ts_ms
    ts_ms=$(now_ms)

    if command -v jq >/dev/null 2>&1; then
        local parsed_body
        if printf '%s' "$body" | jq -e . >/dev/null 2>&1; then
            parsed_body=$(printf '%s' "$body" | jq -c .)
        else
            parsed_body=$(printf '%s' "$body" | jq -R -c .)
        fi
        jq -nc \
            --arg ts "$ts_ms" \
            --arg status "$status" \
            --argjson body "$parsed_body" \
            '{ts_ms: ($ts|tonumber), status: $status, body: $body}' \
            >>"$READYZ_TIMELINE_PATH" 2>/dev/null && return
    fi

    # Fallback: log as a flat string if jq is unavailable
    local safe_body="${body//\"/\\\"}"
    printf '{"ts_ms":%s,"status":"%s","body":"%s"}\n' "$ts_ms" "$status" "$safe_body" \
        >>"$READYZ_TIMELINE_PATH"
}

dump_env_summary() {
    log_line INFO "env: AOS_SERVER_PORT=$AOS_SERVER_PORT AOS_VAR_DIR=$AOS_VAR_DIR SKIP_WORKER=$SKIP_WORKER"
    local server_bin=""
    for candidate in target/release/aos-server target/debug/aos-server; do
        if [ -f "$candidate" ]; then
            server_bin="$candidate"
            break
        fi
    done
    log_line INFO "paths: backend_bin=${server_bin:-missing} script_log=$SCRIPT_LOG backend_log=$AOS_LOG_DIR/backend.log"
}

quarantine_artifact() {
    local path="$1"
    local reason="$2"
    ensure_var_dirs
    local quarantine_dir="$AOS_VAR_DIR/run/quarantine"
    mkdir -p "$quarantine_dir"
    local ts
    ts=$(date +%s)
    local dest="$quarantine_dir/$(basename "$path").$ts"
    mv "$path" "$dest" 2>/dev/null || rm -f "$path"
    log_line WARN "quarantined $path ($reason) -> $dest"
}

check_stale_artifacts() {
    local pid_files=("$AOS_VAR_DIR/backend.pid" "$AOS_VAR_DIR/worker.pid")
    for pf in "${pid_files[@]}"; do
        if [ -f "$pf" ]; then
            local pid
            pid=$(cat "$pf" 2>/dev/null)
            if [ -n "$pid" ] && ! kill -0 "$pid" 2>/dev/null; then
                quarantine_artifact "$pf" "stale-pid"
            fi
        fi
    done
    if command -v lsof >/dev/null 2>&1; then
        local sockets=("$AOS_VAR_DIR/run/worker.sock" "$AOS_VAR_DIR/run/backend.sock")
        for sock in "${sockets[@]}"; do
            # macOS `lsof` does not reliably match UNIX sockets by relative path
            # (it reports the socket name as an absolute path). Keep hygiene checks
            # conservative by always probing the absolute path.
            local sock_abs="$sock"
            if [[ "$sock_abs" != /* ]]; then
                sock_abs="$SCRIPT_DIR/$sock_abs"
            fi
            if [ -S "$sock" ] && ! lsof "$sock_abs" >/dev/null 2>&1; then
                quarantine_artifact "$sock" "stale-socket"
            fi
        done
    fi
}

check_ui_assets() {
    local static_dir="$SCRIPT_DIR/crates/adapteros-server/static"
    if [ ! -d "$static_dir" ]; then
        log_line WARN "ui:assets missing (dir=$static_dir). Build with: cd crates/adapteros-ui && trunk build --release"
        return 1
    fi
    local wasm_count
    wasm_count="$(ls "$static_dir"/*.wasm 2>/dev/null | wc -l | tr -d ' ')"
    if [ ! -f "$static_dir/index.html" ] || [ "$wasm_count" -eq 0 ]; then
        log_line WARN "ui:assets incomplete (index=$( [ -f "$static_dir/index.html" ] && echo yes || echo no ), wasm=$wasm_count)"
        return 1
    fi
    log_line INFO "ui:assets ok (index.html, wasm=$wasm_count)"
    return 0
}

resolve_model_id_for_model_path() {
    local model_path="$1"
    local db_path="$AOS_VAR_DIR/aos-cp.sqlite3"
    if [ ! -f "$db_path" ]; then
        return 1
    fi

    local abs_path="$model_path"
    if [[ "$abs_path" != /* ]]; then
        abs_path="$SCRIPT_DIR/${abs_path#./}"
    fi

    # Normalize common path wrinkles:
    # - env-loader may construct "..././var/..." when AOS_MODEL_PATH starts with "./"
    # - historical DB rows may store either absolute or repo-relative model_path
    local abs_clean raw_clean
    abs_clean="$(printf "%s" "$abs_path" | sed 's#/\./#/#g')"
    raw_clean="$(printf "%s" "$model_path" | sed 's#/\./#/#g')"

    local norm_path="$model_path"
    if [[ "$norm_path" == ./* ]]; then
        norm_path="${norm_path#./}"
    fi
    local norm_clean
    norm_clean="$(printf "%s" "$norm_path" | sed 's#/\./#/#g')"

    local rel_from_root=""
    if [ -n "${SCRIPT_DIR:-}" ] && [[ "$abs_clean" == "$SCRIPT_DIR/"* ]]; then
        rel_from_root="${abs_clean#"$SCRIPT_DIR/"}"
    fi

    # Escape single quotes for SQLite (SQL string literal)
    local abs_escaped abs_clean_escaped raw_escaped raw_clean_escaped norm_escaped norm_clean_escaped rel_escaped rel_dot_escaped
    abs_escaped="$(printf "%s" "$abs_path" | sed "s/'/''/g")"
    abs_clean_escaped="$(printf "%s" "$abs_clean" | sed "s/'/''/g")"
    raw_escaped="$(printf "%s" "$model_path" | sed "s/'/''/g")"
    raw_clean_escaped="$(printf "%s" "$raw_clean" | sed "s/'/''/g")"
    norm_escaped="$(printf "%s" "$norm_path" | sed "s/'/''/g")"
    norm_clean_escaped="$(printf "%s" "$norm_clean" | sed "s/'/''/g")"
    rel_escaped="$(printf "%s" "$rel_from_root" | sed "s/'/''/g")"
    rel_dot_escaped="$(printf "%s" "./$rel_from_root" | sed "s/'/''/g")"

    local query="
SELECT id
FROM models
WHERE model_path IN ('$abs_escaped', '$abs_clean_escaped', '$raw_escaped', '$raw_clean_escaped', '$norm_escaped', '$norm_clean_escaped', '$rel_escaped', '$rel_dot_escaped')
ORDER BY updated_at DESC
LIMIT 1;"
    local model_id
    model_id="$(sqlite3 "$db_path" "$query" 2>/dev/null | head -1)"
    if [ -z "${model_id:-}" ]; then
        return 1
    fi
    echo "$model_id"
}

load_seeded_model_on_worker() {
    local model_path="$1"
    local model_id
    if ! model_id="$(resolve_model_id_for_model_path "$model_path")"; then
        log_line ERROR "model:resolve failed (no model_id for model_path=$model_path)"
        return 1
    fi

    local base_url="http://localhost:$AOS_SERVER_PORT"
    local url="${base_url}/v1/models/${model_id}/load"
    local tmp="$AOS_VAR_DIR/run/model-load-last.json"
    rm -f "$tmp" 2>/dev/null || true

    local auth_header=""
    if [ -n "${AOS_AUTH_TOKEN:-}" ]; then
        auth_header="Authorization: Bearer ${AOS_AUTH_TOKEN}"
    elif [ -n "${AOS_TOKEN:-}" ]; then
        auth_header="Authorization: Bearer ${AOS_TOKEN}"
    fi

    local timeout_secs="${AOS_MODEL_LOAD_TIMEOUT_SECS:-120}"
    local start_ts now elapsed
    start_ts="$(date +%s)"
    local load_request_sent=0
    local just_sent_request=0
    local last_model_phase=""

    while true; do
        # Poll DB for model status first so we can dedupe concurrent callers
        # (e.g., two ./start invocations) and avoid duplicate /load requests.
        local db_status="" db_error="" memory_mb=""
        if command -v sqlite3 >/dev/null 2>&1 && [ -f "$AOS_VAR_DIR/aos-cp.sqlite3" ]; then
            db_status="$(sqlite3 "$AOS_VAR_DIR/aos-cp.sqlite3" \
                "SELECT status FROM base_model_status WHERE tenant_id='default' AND model_id='$model_id' ORDER BY updated_at DESC LIMIT 1;" \
                2>/dev/null | head -1)"
            db_error="$(sqlite3 "$AOS_VAR_DIR/aos-cp.sqlite3" \
                "SELECT error_message FROM base_model_status WHERE tenant_id='default' AND model_id='$model_id' ORDER BY updated_at DESC LIMIT 1;" \
                2>/dev/null | head -1)"
            memory_mb="$(sqlite3 "$AOS_VAR_DIR/aos-cp.sqlite3" \
                "SELECT memory_usage_mb FROM base_model_status WHERE tenant_id='default' AND model_id='$model_id' ORDER BY updated_at DESC LIMIT 1;" \
                2>/dev/null | head -1)"
        fi

        # Send load request at most once, and only if there isn't already
        # an in-progress load for this model.
        just_sent_request=0
        if [ "$load_request_sent" -eq 0 ]; then
            if [ "$db_status" = "loading" ]; then
                log_line INFO "model:load in-flight already; waiting model_id=$model_id"
                load_request_sent=1
            else
                local status="000"
                if [ -n "$auth_header" ]; then
                    status=$(curl -s -o "$tmp" -w "%{http_code}" --max-time 120 \
                        -H "Content-Type: application/json" -H "$auth_header" \
                        -d '{}' "$url" 2>/dev/null || echo "000")
                else
                    status=$(curl -s -o "$tmp" -w "%{http_code}" --max-time 120 \
                        -H "Content-Type: application/json" \
                        -d '{}' "$url" 2>/dev/null || echo "000")
                fi

                if [ "$status" != "200" ]; then
                    log_line ERROR "model:load failed status=$status model_id=$model_id"
                    return 1
                fi
                load_request_sent=1
                just_sent_request=1
            fi
        fi

        # Map DB status to progress percentage and label
        local mpct=20
        local mlabel="Sending load request..."
        case "$db_status" in
            ready|loaded)
                term_clear_row
                # Store memory info for caller to display
                MODEL_LOAD_MEMORY_MB="${memory_mb:-}"
                return 0
                ;;
            loading)
                mpct=60
                mlabel="Loading model to RAM..."
                ;;
            error)
                if [ "$just_sent_request" -eq 1 ]; then
                    mpct=40
                    mlabel="Load requested, awaiting status update..."
                else
                    term_clear_row
                    log_line WARN "model:load worker reported error model_id=$model_id error=${db_error:-unknown}"
                    return 1
                fi
                ;;
            "")
                # Row not yet created - waiting for worker to pick up
                if [ "$load_request_sent" -eq 1 ]; then
                    mpct=35
                    mlabel="Waiting for worker..."
                fi
                ;;
            *)
                log_line WARN "model:load unexpected db status model_id=$model_id status=$db_status"
                return 1
                ;;
        esac

        # Render progress
        if [ "$AOS_CAN_ANIMATE" -eq 1 ]; then
            print_progress_animated "$mpct" 100 "$mlabel"
        elif [ "$db_status" != "$last_model_phase" ]; then
            echo "  [$mpct%] $mlabel"
        fi
        last_model_phase="$db_status"

        now="$(date +%s)"
        elapsed=$((now - start_ts))
        if [ "$elapsed" -ge "$timeout_secs" ]; then
            term_clear_row
            log_line ERROR "model:load timeout model_id=$model_id waited_secs=$elapsed last_status=${db_status:-none}"
            return 1
        fi

        sleep 1
    done
}

# Memory info from last model load (set by load_seeded_model_on_worker)
MODEL_LOAD_MEMORY_MB=""

