#!/bin/bash
# adapterOS Boot Script
#
# Usage:
#   ./start              Start backend + worker
#   ./start up           Same as above
#   ./start down         Graceful shutdown
#   ./start status       Show service status
#   ./start backend      Start backend only
#   ./start worker       Start worker only
#   ./start secd         Start Secure Enclave Daemon only
#   ./start node         Start Node Agent only
#   ./start preflight    Run system checks without starting
#   ./start help         Show this help
#
# UI: Backend serves Leptos WASM from static/. For dev, run `trunk serve`
#     in crates/adapteros-ui/ separately.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Keep local builds on the canonical cache root unless explicitly overridden.
: "${CARGO_TARGET_DIR:=target}"
export CARGO_TARGET_DIR

# Source libraries
source scripts/lib/freeze-guard.sh
source scripts/lib/env-loader.sh
source scripts/lib/manifest-reader.sh
source scripts/lib/model-config.sh
source scripts/lib/ports.sh

# Set SCRIPT_DIR for path normalization
export SCRIPT_DIR

# Unified Run ID for traceability
if command -v uuidgen > /dev/null; then
    export AOS_RUN_ID=${AOS_RUN_ID:-$(uuidgen)}
else
    export AOS_RUN_ID=${AOS_RUN_ID:-$(date +%s)-$(head -c 4 /dev/urandom | od -An -t x4 | tr -d ' ')}
fi
export AOS_DEBUG_RUN_ID=$AOS_RUN_ID

# Load .env file if it exists (provides default values)
# Values can still be overridden by environment variables set before running ./start
load_env_file ".env" --no-override || true

# If manifest exists and AOS_CONFIG is not explicitly set, use manifest as config.
# The manifest is a superset of cp.toml — unknown sections are silently ignored
# by the Rust config loader.
if manifest_exists "$AOS_MANIFEST_FILE" && [ -z "${AOS_CONFIG+x}" ]; then
    export AOS_CONFIG_PATH="$SCRIPT_DIR/$AOS_MANIFEST_FILE"
fi

# Bridge manifest sections to env vars.
# Uses : "${VAR:=$val}" pattern — only sets if not already set, preserving:
#   CLI flags > env vars > .env > manifest.toml > built-in defaults
bridge_manifest_to_env() {
    local manifest="$AOS_MANIFEST_FILE"
    manifest_exists "$manifest" || return 0

    local val

    # [services] → SKIP_* flags (inverted: services.worker=false → SKIP_WORKER=1)
    val="$(toml_read "$manifest" services worker 2>/dev/null || true)"
    if [ "$val" = "false" ] && [ -z "${SKIP_WORKER+x}" ]; then
        SKIP_WORKER=1
    fi
    val="$(toml_read "$manifest" services secd 2>/dev/null || true)"
    if [ "$val" = "false" ] && [ -z "${SKIP_SECD+x}" ]; then
        SKIP_SECD=1
    fi
    val="$(toml_read "$manifest" services node 2>/dev/null || true)"
    if [ "$val" = "false" ] && [ -z "${SKIP_NODE+x}" ]; then
        SKIP_NODE=1
    fi

    # [boot] → AOS_* vars
    val="$(toml_read "$manifest" boot verify_chat 2>/dev/null || true)"
    if [ "$val" = "true" ] && [ -z "${AOS_VERIFY_CHAT+x}" ]; then
        AOS_VERIFY_CHAT=1
    fi
    val="$(toml_read "$manifest" boot health_timeout_secs 2>/dev/null || true)"
    [ -n "$val" ] && : "${AOS_HEALTH_TIMEOUT:=$val}"
    val="$(toml_read "$manifest" boot readyz_timeout_secs 2>/dev/null || true)"
    [ -n "$val" ] && : "${AOS_READYZ_TIMEOUT:=$val}"
    val="$(toml_read "$manifest" boot log_profile 2>/dev/null || true)"
    [ -n "$val" ] && : "${AOS_LOG_PROFILE:=$val}"

    # [model] → AOS_MODEL_* vars
    val="$(toml_read "$manifest" model path 2>/dev/null || true)"
    [ -n "$val" ] && : "${AOS_MODEL_PATH:=$val}"
    val="$(toml_read "$manifest" model backend 2>/dev/null || true)"
    [ -n "$val" ] && : "${AOS_MODEL_BACKEND:=$val}"
    val="$(toml_read "$manifest" model manifest 2>/dev/null || true)"
    [ -n "$val" ] && : "${AOS_WORKER_MANIFEST:=$val}"
    val="$(toml_read "$manifest" model tokenizer_path 2>/dev/null || true)"
    [ -n "$val" ] && : "${AOS_TOKENIZER_PATH:=$val}"

    # [server] → AOS_SERVER_PORT
    val="$(toml_read "$manifest" server port 2>/dev/null || true)"
    [ -n "$val" ] && : "${AOS_SERVER_PORT:=$val}"
}

bridge_manifest_to_env

# Resolve model/cache/base-id/manifest using shared policy so start and
# service-manager read the same runtime config surfaces.
aos_resolve_model_runtime_env "$SCRIPT_DIR"

# Resolve server port and dev bypass from config using toml_read
# (replaces previous ad-hoc awk parsers)
if [ -z "${AOS_SERVER_PORT:-}" ]; then
    local_config="${AOS_CONFIG_PATH:-${AOS_CONFIG:-$SCRIPT_DIR/configs/cp.toml}}"
    if [ -f "$local_config" ]; then
        port_from_config="$(toml_read "$local_config" server port 2>/dev/null || true)"
        if [ -n "$port_from_config" ]; then
            AOS_SERVER_PORT="$port_from_config"
        fi
    fi
fi

if [ -z "${AOS_DEV_NO_AUTH:-}" ]; then
    local_config="${AOS_CONFIG_PATH:-${AOS_CONFIG:-$SCRIPT_DIR/configs/cp.toml}}"
    if [ -f "$local_config" ]; then
        dev_bypass_from_config="$(toml_read "$local_config" security dev_bypass 2>/dev/null || true)"
        if [ "$dev_bypass_from_config" = "true" ]; then
            export AOS_DEV_NO_AUTH=1
        fi
    fi
fi

# Configuration (can be overridden via environment)
aos_apply_port_pane_defaults
: "${AOS_VAR_DIR:=var}"
: "${AOS_LOG_DIR:=$AOS_VAR_DIR/logs}"
: "${SKIP_WORKER:=0}"
: "${SKIP_SECD:=0}"
: "${SKIP_NODE:=0}"
: "${AOS_QUICK_BOOT:=0}"
: "${AOS_VERIFY_CHAT:=0}"
: "${AOS_LOG_PROFILE:=json}"
: "${AOS_DEV_LOG_RETENTION_DAYS:=7}"
: "${AOS_DEV_CLIENT_ERROR_RETENTION_DAYS:=30}"

# Align control plane URL for worker registration if not set
export AOS_CP_URL

# Run quick validation (non-fatal, just warnings)
validate_env_quick || true

VERBOSE=0
TRACE=0
SCRIPT_LOG="$AOS_LOG_DIR/start.log"
READYZ_TIMELINE_PATH="$AOS_LOG_DIR/readyz-timeline.jsonl"
DEBUG_LOG_PATH="$AOS_LOG_DIR/debug.jsonl"

# Animation characters
SPINNER_CHARS="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
PROGRESS_CHARS="▁▂▃▄▅▆▇█"
CHECK_MARK="✓"
CROSS_MARK="✗"
ARROW="→"

# Progress tracking (phase-driven via /healthz/startup; see boot_phase_to_pct)
POLL_BOOT_STATE=""
POLL_FAIL_REASON=""
POLL_FAIL_PHASE=""
POLL_FAIL_ACTION=""
POLL_FAIL_ERROR=""

# =============================================================================
# Animation & Progress Helpers
# =============================================================================

# If stdout is a TTY, we can safely animate using in-place row updates.
# If not (CI, redirected output), suppress in-place animations to avoid log spam.
AOS_CAN_ANIMATE=0
if [ -t 1 ] && [ "${AOS_NO_ANIMATION:-0}" != "1" ]; then
    AOS_CAN_ANIMATE=1
fi

# Clear exactly one terminal row (current line) and return carriage to column 0.
term_clear_row() {
    [ "$AOS_CAN_ANIMATE" -eq 1 ] || return 0
    printf "\r\033[2K"
}

# Print the adapterOS banner
print_banner() {
    echo ""
    printf "${FG_CYAN}"
    cat << 'EOF'
    ___       __            __            ____  _____
   /   | ____/ /___ _____  / /____  _____/ __ \/ ___/
  / /| |/ __  / __ `/ __ \/ __/ _ \/ ___/ / / /\__ \
 / ___ / /_/ / /_/ / /_/ / /_/  __/ /  / /_/ /___/ /
/_/  |_\__,_/\__,_/ .___/\__/\___/_/   \____//____/
                 /_/
EOF
    printf "${FG_RESET}"
    echo ""
}

# Spinner animation for background tasks
# Usage: start_spinner "message" ; do_work ; stop_spinner
SPINNER_PID=""
start_spinner() {
    local msg="$1"
    if [ "$AOS_CAN_ANIMATE" -ne 1 ]; then
        # Non-interactive output: emit a single line and skip background animation.
        echo "  $msg"
        SPINNER_PID=""
        return 0
    fi
    (
        local i=0
        while true; do
            term_clear_row
            printf "  ${FG_CYAN}${SPINNER_CHARS:$i:1}${FG_RESET} %s" "$msg"
            i=$(( (i + 1) % ${#SPINNER_CHARS} ))
            sleep 0.1
        done
    ) &
    SPINNER_PID=$!
    disown
}

stop_spinner() {
    if [ -n "$SPINNER_PID" ]; then
        kill "$SPINNER_PID" 2>/dev/null || true
        wait "$SPINNER_PID" 2>/dev/null || true
        SPINNER_PID=""
        term_clear_row
    fi
}

# Print a step with status
print_step() {
    local status="$1"  # pending, running, success, error
    local msg="$2"

    # If a progress/spinner line was just rendered without a newline, make sure
    # this step starts on a clean single row.
    term_clear_row

    case "$status" in
        pending)
            echo -e "  ${FG_YELLOW}○${FG_RESET} $msg"
            ;;
        running)
            echo -e "  ${FG_CYAN}◐${FG_RESET} $msg"
            ;;
        success)
            echo -e "  ${FG_GREEN}${CHECK_MARK}${FG_RESET} $msg"
            ;;
        error)
            echo -e "  ${FG_RED}${CROSS_MARK}${FG_RESET} $msg"
            ;;
    esac
}

# Update a step in place (moves cursor up)
update_step() {
    local status="$1"
    local msg="$2"
    if [ "$AOS_CAN_ANIMATE" -ne 1 ]; then
        # Non-interactive output: don't emit cursor movement/clear escapes.
        print_step "$status" "$msg"
        return 0
    fi

    # Move up one row (the previously printed step) and clear exactly that row.
    printf "\033[1A\033[2K"
    print_step "$status" "$msg"
}

# Animated progress bar with smooth animation
print_progress() {
    local current="$1"
    local total="$2"
    [ "$total" -eq 0 ] && total=1  # Avoid division by zero
    local width=40
    local pct=$((current * 100 / total))
    [ $pct -gt 100 ] && pct=100  # Cap at 100%
    local filled=$((current * width / total))
    [ $filled -gt $width ] && filled=$width  # Cap at width
    local empty=$((width - filled))

    term_clear_row
    printf "  ${FG_CYAN}[${FG_RESET}"
    if [ $filled -gt 0 ]; then
        printf "${FG_GREEN}%${filled}s${FG_RESET}" | tr ' ' '█'
    fi
    if [ $filled -lt $width ]; then
        printf "%${empty}s" | tr ' ' '░'
    fi
    printf "${FG_CYAN}]${FG_RESET} ${FG_BOLD}%3d%%${FG_RESET}" "$pct"
}

# Animated progress bar with spinner overlay
print_progress_animated() {
    local current="$1"
    local total="$2"
    local msg="${3:-}"
    [ "$AOS_CAN_ANIMATE" -eq 1 ] || return 0
    [ "$total" -eq 0 ] && total=1  # Avoid division by zero
    local width=40
    local pct=$((current * 100 / total))
    [ $pct -gt 100 ] && pct=100  # Cap at 100%
    local filled=$((current * width / total))
    [ $filled -gt $width ] && filled=$width  # Cap at width
    local empty=$((width - filled))
    
    # Get spinner character
    local spinner_idx=$((current % ${#SPINNER_CHARS}))
    local spinner_char="${SPINNER_CHARS:$spinner_idx:1}"

    term_clear_row
    printf "  ${FG_CYAN}${spinner_char}${FG_RESET} ${FG_CYAN}[${FG_RESET}"
    printf "${FG_GREEN}%${filled}s${FG_RESET}" | tr ' ' '█'
    printf "%${empty}s" | tr ' ' '░'
    printf "${FG_CYAN}]${FG_RESET} ${FG_BOLD}%3d%%${FG_RESET}" "$pct"
    if [ -n "$msg" ]; then
        printf " ${FG_CYAN}%s${FG_RESET}" "$msg"
    fi
}

# =============================================================================
# Boot Phase Mapping (driven by /healthz/startup JSON)
# =============================================================================

# Maps boot_state string from /healthz/startup to a progress percentage.
# Source of truth: crates/adapteros-boot/src/phase.rs (BootPhase::as_str())
boot_phase_to_pct() {
    case "$1" in
        stopped)             echo 0 ;;
        starting)            echo 5 ;;
        security-init)       echo 8 ;;
        executor-init)       echo 12 ;;
        preflight)           echo 15 ;;
        boot-invariants)     echo 18 ;;
        db-connecting)       echo 22 ;;
        migrating)           echo 30 ;;
        post-db-invariants)  echo 35 ;;
        startup-recovery)    echo 38 ;;
        seeding)             echo 42 ;;
        loading-policies)    echo 48 ;;
        starting-backend)    echo 55 ;;
        loading-base-models) echo 62 ;;
        loading-adapters)    echo 70 ;;
        worker-discovery)    echo 78 ;;
        router-build)        echo 84 ;;
        finalize)            echo 90 ;;
        bind)                echo 95 ;;
        ready|fully-ready)   echo 100 ;;
        degraded)            echo 100 ;;
        failed)              echo -1 ;;
        *)                   echo 0 ;;
    esac
}

# Maps boot_state to a human-readable label for the progress bar.
boot_phase_to_label() {
    case "$1" in
        stopped)             echo "Stopped" ;;
        starting)            echo "Starting up..." ;;
        security-init)       echo "Initializing security..." ;;
        executor-init)       echo "Initializing executor..." ;;
        preflight)           echo "Running preflight checks..." ;;
        boot-invariants)     echo "Checking boot invariants..." ;;
        db-connecting)       echo "Connecting to database..." ;;
        migrating)           echo "Running migrations..." ;;
        post-db-invariants)  echo "Post-migration checks..." ;;
        startup-recovery)    echo "Running startup recovery..." ;;
        seeding)             echo "Seeding data..." ;;
        loading-policies)    echo "Loading policies..." ;;
        starting-backend)    echo "Starting backend services..." ;;
        loading-base-models) echo "Loading base models..." ;;
        loading-adapters)    echo "Loading adapters..." ;;
        worker-discovery)    echo "Discovering workers..." ;;
        router-build)        echo "Building router..." ;;
        finalize)            echo "Finalizing..." ;;
        bind)                echo "Binding to port..." ;;
        ready)               echo "Ready" ;;
        fully-ready)         echo "Fully ready" ;;
        degraded)            echo "Ready (degraded)" ;;
        failed)              echo "Failed" ;;
        *)                   echo "Booting..." ;;
    esac
}

# Extract boot_state from /healthz/startup JSON response.
# Uses jq if available, falls back to grep/sed.
extract_boot_state() {
    local body="$1"
    if command -v jq >/dev/null 2>&1; then
        printf '%s' "$body" | jq -r '.boot_state // empty' 2>/dev/null
    else
        printf '%s' "$body" | grep -o '"boot_state":"[^"]*"' | sed 's/.*"boot_state":"\([^"]*\)".*/\1/'
    fi
}

# Extract a string field from JSON (jq with grep/sed fallback).
extract_json_field() {
    local body="$1"
    local field="$2"
    if command -v jq >/dev/null 2>&1; then
        printf '%s' "$body" | jq -r ".$field // empty" 2>/dev/null
    else
        printf '%s' "$body" | grep -o "\"$field\":\"[^\"]*\"" | sed "s/.*\"$field\":\"\([^\"]*\)\".*/\1/"
    fi
}

# =============================================================================
# poll_backend_startup - Phase-driven backend health wait
# =============================================================================
#
# Usage: poll_backend_startup <pid> <timeout_secs>
# Returns: 0 = ready, 1 = crash/timeout, 2 = boot failure (structured error)
#
# Polls /healthz/startup for real boot phase data. Falls back to /healthz
# if /healthz/startup returns 404 or connection refused (old binary).
poll_backend_startup() {
    local backend_pid="$1"
    local timeout_secs="$2"
    local startup_url="http://localhost:$AOS_SERVER_PORT/healthz/startup"
    local healthz_url="http://localhost:$AOS_SERVER_PORT/healthz"
    local waited=0
    local last_phase=""
    local use_startup_endpoint=1  # optimistic; downgrade on 404
    local got_first_response=0

    while [ $waited -lt "$timeout_secs" ]; do
        # Crash detection
        if [ -n "$backend_pid" ] && ! kill -0 "$backend_pid" 2>/dev/null; then
            term_clear_row
            POLL_FAIL_REASON="CRASHED"
            POLL_FAIL_PHASE="${last_phase:-pre-listen}"
            return 1
        fi

        if [ "$use_startup_endpoint" -eq 1 ]; then
            # Try /healthz/startup (returns JSON body even on 503 during boot)
            local tmp_body
            tmp_body="$AOS_VAR_DIR/run/.startup-poll.json"
            local http_code
            http_code=$(curl -sf -o "$tmp_body" -w "%{http_code}" --max-time 2 "$startup_url" 2>/dev/null || echo "000")

            if [ "$http_code" = "000" ]; then
                # Connection refused - server not yet listening
                if [ "$AOS_CAN_ANIMATE" -eq 1 ]; then
                    print_progress_animated $waited "$timeout_secs" "Launching backend..."
                elif [ "$got_first_response" -eq 0 ] && [ "$waited" -eq 0 ]; then
                    echo "  Launching backend..."
                fi
                sleep 1
                ((waited++))
                continue
            fi

            if [ "$http_code" = "404" ]; then
                # Old binary without /healthz/startup - fall back
                use_startup_endpoint=0
                rm -f "$tmp_body" 2>/dev/null
                continue
            fi

            got_first_response=1
            local body=""
            [ -f "$tmp_body" ] && body="$(cat "$tmp_body" 2>/dev/null)"
            rm -f "$tmp_body" 2>/dev/null

            local boot_state
            boot_state="$(extract_boot_state "$body")"

            if [ -z "$boot_state" ]; then
                # Malformed response - treat like pre-listen
                sleep 1
                ((waited++))
                continue
            fi

            # Failed state - structured error
            if [ "$boot_state" = "failed" ]; then
                term_clear_row
                POLL_FAIL_REASON="BOOT_FAILED"
                POLL_FAIL_PHASE="$(extract_json_field "$body" "failed_phase")"
                POLL_FAIL_ACTION="$(extract_json_field "$body" "next_action")"
                POLL_FAIL_ERROR="$(extract_json_field "$body" "last_error_code")"
                return 2
            fi

            # Ready states
            if [ "$boot_state" = "ready" ] || [ "$boot_state" = "fully-ready" ] || [ "$boot_state" = "degraded" ]; then
                term_clear_row
                POLL_BOOT_STATE="$boot_state"
                return 0
            fi

            # In-progress phase - render progress
            local pct
            pct="$(boot_phase_to_pct "$boot_state")"
            local label
            label="$(boot_phase_to_label "$boot_state")"

            if [ "$AOS_CAN_ANIMATE" -eq 1 ]; then
                print_progress_animated "$pct" 100 "$label"
            elif [ "$boot_state" != "$last_phase" ]; then
                echo "  [$pct%] $label"
            fi
            last_phase="$boot_state"
        else
            # Fallback: basic /healthz polling (old binary)
            if [ "$AOS_CAN_ANIMATE" -eq 1 ]; then
                print_progress_animated $waited "$timeout_secs" "Waiting for backend health..."
            elif [ "$waited" -eq 0 ]; then
                echo "  Waiting for backend health..."
            fi
            if curl -sf --max-time 2 "$healthz_url" >/dev/null 2>&1; then
                term_clear_row
                POLL_BOOT_STATE="ready"
                return 0
            fi
        fi

        sleep 1
        ((waited++))
    done

    # Timeout
    term_clear_row
    POLL_FAIL_REASON="TIMEOUT"
    POLL_FAIL_PHASE="${last_phase:-unknown}"
    return 1
}

# Enhanced progress bar for operations with time estimate
print_progress_with_time() {
    local current="$1"
    local total="$2"
    local elapsed="$3"
    local msg="${4:-}"
    [ "$AOS_CAN_ANIMATE" -eq 1 ] || return 0
    [ "$total" -eq 0 ] && total=1  # Avoid division by zero
    local width=40
    local pct=$((current * 100 / total))
    [ $pct -gt 100 ] && pct=100  # Cap at 100%
    local filled=$((current * width / total))
    [ $filled -gt $width ] && filled=$width  # Cap at width
    local empty=$((width - filled))
    
    # Estimate remaining time
    local remaining=""
    if [ $current -gt 0 ] && [ $elapsed -gt 0 ]; then
        local rate=$((current * 1000 / elapsed))
        if [ $rate -gt 0 ]; then
            local remaining_ms=$(((total - current) * 1000 / rate))
            if [ $remaining_ms -lt 1000 ]; then
                remaining="${remaining_ms}ms"
            elif [ $remaining_ms -lt 60000 ]; then
                remaining="$((remaining_ms / 1000))s"
            else
                remaining="$((remaining_ms / 60000))m"
            fi
        fi
    fi

    term_clear_row
    printf "  ${FG_CYAN}[${FG_RESET}"
    printf "${FG_GREEN}%${filled}s${FG_RESET}" | tr ' ' '█'
    printf "%${empty}s" | tr ' ' '░'
    printf "${FG_CYAN}]${FG_RESET} ${FG_BOLD}%3d%%${FG_RESET}" "$pct"
    if [ -n "$msg" ]; then
        printf " ${FG_CYAN}%s${FG_RESET}" "$msg"
    fi
    if [ -n "$remaining" ]; then
        printf " ${FG_YELLOW}(~${remaining})${FG_RESET}"
    fi
}

# Wait for service to be ready with animation
wait_for_service() {
    local name="$1"
    local check_cmd="$2"
    local timeout="${3:-30}"
    local msg="$4"

    print_step "running" "$msg"

    local waited=0
    while [ $waited -lt $timeout ]; do
        if eval "$check_cmd" >/dev/null 2>&1; then
            update_step "success" "$msg"
            return 0
        fi
        sleep 1
        ((waited++))
    done

    update_step "error" "$msg (timeout)"
    return 1
}

# =============================================================================
# aosctl Installation
# =============================================================================

AOSCTL_INSTALLED_FLAG="$AOS_VAR_DIR/.aosctl-path-offered"

check_aosctl_installation() {
    # Skip if we've already offered
    if [ -f "$AOSCTL_INSTALLED_FLAG" ]; then
        return 0
    fi

    # Skip if aosctl is already in PATH
    if command -v aosctl >/dev/null 2>&1; then
        touch "$AOSCTL_INSTALLED_FLAG"
        return 0
    fi

    # Check if we have a built aosctl
    local aosctl_bin=""
    if [ -f "target/release/aosctl" ]; then
        aosctl_bin="target/release/aosctl"
    elif [ -f "target/debug/aosctl" ]; then
        aosctl_bin="target/debug/aosctl"
    else
        # No binary to install
        return 0
    fi

    echo ""
    echo -e "${FG_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
    echo ""
    echo -e "  ${FG_YELLOW}aosctl${FG_RESET} is not in your PATH."
    echo ""
    echo "  The aosctl CLI provides commands for managing adapters, training,"
    echo "  inference, and system administration."
    echo ""
    echo "  Options:"
    echo -e "    ${FG_GREEN}1${FG_RESET}) Install to /usr/local/bin (requires sudo)"
    echo -e "    ${FG_GREEN}2${FG_RESET}) Install to ~/bin (no sudo required)"
    echo -e "    ${FG_GREEN}3${FG_RESET}) Add to PATH via shell config (~/.zshrc or ~/.bashrc)"
    echo -e "    ${FG_GREEN}s${FG_RESET}) Skip (you can always use ./aosctl)"
    echo ""

    read -p "  Choose an option [1/2/3/s]: " -n 1 -r choice
    echo ""

    case "$choice" in
        1)
            echo ""
            print_step "running" "Installing aosctl to /usr/local/bin..."
            if sudo ln -sf "$(pwd)/$aosctl_bin" /usr/local/bin/aosctl 2>/dev/null; then
                # sudo may prompt; avoid cursor-up rewrites which can corrupt the prompt line.
                print_step "success" "Installed aosctl to /usr/local/bin"
                echo ""
                echo "  You can now run: ${FG_GREEN}aosctl --help${FG_RESET}"
            else
                print_step "error" "Failed to install (try option 2 or 3)"
            fi
            ;;
        2)
            echo ""
            mkdir -p "$HOME/bin"
            print_step "running" "Installing aosctl to ~/bin..."
            ln -sf "$(pwd)/$aosctl_bin" "$HOME/bin/aosctl"
            update_step "success" "Installed aosctl to ~/bin"

            # Check if ~/bin is in PATH
            if [[ ":$PATH:" != *":$HOME/bin:"* ]]; then
                echo ""
                echo -e "  ${FG_YELLOW}Note:${FG_RESET} ~/bin is not in your PATH."
                echo "  Add this to your ~/.zshrc or ~/.bashrc:"
                echo ""
                echo -e "    ${FG_CYAN}export PATH=\"\$HOME/bin:\$PATH\"${FG_RESET}"
                echo ""
            else
                echo ""
                echo "  You can now run: ${FG_GREEN}aosctl --help${FG_RESET}"
            fi
            ;;
        3)
            echo ""
            local shell_rc=""
            if [ -n "$ZSH_VERSION" ] || [ -f "$HOME/.zshrc" ]; then
                shell_rc="$HOME/.zshrc"
            else
                shell_rc="$HOME/.bashrc"
            fi

            local aos_path="export PATH=\"$(pwd):\$PATH\"  # adapterOS"

            if grep -q "adapterOS" "$shell_rc" 2>/dev/null; then
                print_step "success" "PATH already configured in $shell_rc"
            else
                print_step "running" "Adding to $shell_rc..."
                echo "" >> "$shell_rc"
                echo "# adapterOS CLI" >> "$shell_rc"
                echo "$aos_path" >> "$shell_rc"
                update_step "success" "Added to $shell_rc"
                echo ""
                echo "  Run this to apply now: ${FG_CYAN}source $shell_rc${FG_RESET}"
                echo "  Or start a new terminal."
            fi
            ;;
        s|S|"")
            echo ""
            echo "  Skipped. You can use ${FG_CYAN}./aosctl${FG_RESET} from this directory."
            ;;
    esac

    # Mark as offered
    mkdir -p "$AOS_VAR_DIR"
    touch "$AOSCTL_INSTALLED_FLAG"
    echo ""
    echo -e "${FG_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${FG_RESET}"
    echo ""
}

