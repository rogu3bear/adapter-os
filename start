# Start backend with progress animation
start_backend_animated() {
    log_line INFO "backend:start requested (port=$AOS_SERVER_PORT verbose=$VERBOSE trace=$TRACE)"

    ensure_var_dirs

    # Port checks may print diagnostics and/or prompt; never run them while an animation is active.
    if ! freeze_check_port "$AOS_SERVER_PORT" "Backend API" 2>/dev/null; then
        print_step "error" "Backend API - port $AOS_SERVER_PORT in use"
        log_line ERROR "backend:start blocked (port-in-use $AOS_SERVER_PORT)"
        return 1
    fi

    print_step "running" "Starting Backend API..."

    # Delegate to service-manager
    if [ -x scripts/service-manager.sh ]; then
        local tail_pid=""
        # Capture stderr to show helpful error messages (e.g., "binary not found")
        local service_manager_stderr
        service_manager_stderr=$(mktemp)
        start_spinner "Launching backend process..."
        if scripts/service-manager.sh start-backend >/dev/null 2>"$service_manager_stderr"; then
            stop_spinner
            rm -f "$service_manager_stderr"
            if [ $VERBOSE -eq 1 ] || [ $TRACE -eq 1 ]; then
                touch "$AOS_LOG_DIR/backend.log"
                tail -n 20 -F "$AOS_LOG_DIR/backend.log" &
                tail_pid=$!
            fi
            # Wait for health check (configurable timeout) with progress
            local waited=0
            local health_timeout="${AOS_HEALTH_TIMEOUT:-15}"
            local backend_pid
            backend_pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
            while [ $waited -lt "$health_timeout" ]; do
                # Early crash detection: check if process is still alive
                if [ -n "$backend_pid" ] && ! kill -0 "$backend_pid" 2>/dev/null; then
                    term_clear_row
                    update_step "error" "Backend API     ${FG_RED}CRASHED${FG_RESET} (process died during startup)"
                    log_line ERROR "backend:early_crash pid=$backend_pid"
                    [ "${AOS_BOOT_VERBOSE:-0}" = "1" ] && tail -30 "$AOS_VAR_DIR/logs/backend.log" 2>/dev/null
                    append_debug_log \
                        "start_backend_animated:early_crash" \
                        "backend crashed during health wait" \
                        "H1" \
                        "$(printf '{"pid":"%s"}' "$backend_pid")"
                    if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
                    return 1
                fi
                print_progress_animated $waited $health_timeout "Waiting for backend health..."
                if curl -sf --max-time 2 "http://localhost:$AOS_SERVER_PORT/healthz" >/dev/null 2>&1; then
                    term_clear_row
                    local pid
                    pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
                    update_step "success" "Backend API     ${FG_GREEN}READY${FG_RESET}  (PID $pid, port $AOS_SERVER_PORT)"
                    log_line INFO "backend:ready pid=$pid port=$AOS_SERVER_PORT"
                    if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
                    #region agent log
                    append_debug_log \
                        "start_backend_animated:health" \
                        "backend ready" \
                        "H1" \
                        "$(printf '{"pid":"%s","manifest":"%s","backend_port":"%s"}' "$pid" "${AOS_MANIFEST_PATH:-}" "${AOS_SERVER_PORT:-8080}")"
                    #endregion agent log
                    return 0
                fi
                sleep 1
                ((waited++))
            done
            term_clear_row
            # Health check timeout - this is a failure, not success
            local pid
            pid=$(cat "$AOS_VAR_DIR/backend.pid" 2>/dev/null)
            local health_timeout="${AOS_HEALTH_TIMEOUT:-15}"
            if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                update_step "error" "Backend API     ${FG_RED}UNHEALTHY${FG_RESET} (PID $pid, healthz timeout after ${health_timeout}s)"
            else
                update_step "error" "Backend API     ${FG_RED}CRASHED${FG_RESET} (process not running)"
            fi
            log_line ERROR "backend:health_timeout pid=${pid:-none} timeout=${health_timeout}s"
            [ "${AOS_BOOT_VERBOSE:-0}" = "1" ] && tail -20 "$AOS_VAR_DIR/logs/backend.log" 2>/dev/null
            #region agent log
            append_debug_log \
                "start_backend_animated:health_timeout" \
                "backend healthz timeout - treated as failure" \
                "H1" \
                "$(printf '{"pid":"%s","manifest":"%s","backend_port":"%s"}' "$pid" "${AOS_MANIFEST_PATH:-}" "${AOS_SERVER_PORT:-8080}")"
            #endregion agent log
            if [ -n "$tail_pid" ]; then kill "$tail_pid" 2>/dev/null; fi
            return 1
        else
            stop_spinner
            update_step "error" "Backend API - failed to start"
            log_line ERROR "backend:start failed (service-manager start-backend)"
            # Show helpful error messages from service-manager (e.g., "binary not found")
            if [ -s "$service_manager_stderr" ]; then
                echo ""
                echo "${FG_YELLOW}Error details:${FG_RESET}"
                cat "$service_manager_stderr" | sed 's/^/  /'
                echo ""
            fi
            rm -f "$service_manager_stderr"
            #region agent log
            append_debug_log \
                "start_backend_animated:error" \
                "backend start failed" \
                "H1" \
                "$(printf '{"manifest":"%s","backend_port":"%s"}' "${AOS_MANIFEST_PATH:-}" "${AOS_SERVER_PORT:-8080}")"
            #endregion agent log
            return 1
        fi
    else
        update_step "error" "Backend API - service-manager.sh not found"
        return 1
    fi
}

