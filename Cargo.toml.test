[package]
name = "sqlx-offline-test"
version = "0.1.0"
edition = "2021"

[[bin]]
name = "sqlx_offline_test"
path = "sqlx_offline_test.rs"

[dependencies]
sqlx = { version = "0.8", features = ["runtime-tokio", "sqlite", "macros", "chrono", "uuid"] }
tokio = { version = "1.35", features = ["full"] }
chrono = { version = "0.4", features = ["serde"] }
