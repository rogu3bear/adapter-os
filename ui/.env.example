# AdapterOS UI Environment Variables Example
# Copy this file to .env.local for local development

# API Configuration
# These are default ports. For multi-developer setups, use port offsets
# to avoid conflicts (e.g., 8080→8180, 8080→8280).
# See ../CONTRIBUTING.md for the port offset convention.
VITE_API_URL=http://127.0.0.1:8080/api
VITE_SSE_URL=localhost:8080

# Metrics & Monitoring
VITE_METRICS_INTERVAL=500

# Feature Flags
# Enable automatic model loading in chat interface (default: false)
VITE_CHAT_AUTO_LOAD_MODELS=false
