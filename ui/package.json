    "scripts": {
        "dev": "node scripts/dev-server.mjs",
        "service-panel": "node server.js",
        "service-panel:dev": "vite --config vite.config.service-panel.ts",
        "prebuild": "node scripts/ensure-port.mjs --mode=build",
        "build": "tsc --noEmit && vite build",
        "build:service-panel": "tsc --noEmit && vite build --config vite.config.service-panel.ts",
        "build:test": "tsc --noEmit && pnpm test",
        "gen:api-types": "node scripts/generate-types.mjs",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
        "preview": "vite preview",
        "diagnose:health": "node scripts/check-backend-health.mjs",
        "test": "vitest",
        "test:telemetry": "vitest run src/components/__tests__/Telemetry.test.tsx",
    "test:coverage": "vitest --coverage",
        "test:ui": "vitest run --coverage --reporter=lcov",
        "test:a11y": "start-server-and-test dev http://localhost:3200 \"pnpm cypress:run --spec e2e/cypress/e2e/a11y.cy.ts\"",
        "cypress:open": "cypress open",
        "cypress:run": "cypress run",
        "cypress:run:coverage": "CYPRESS_COVERAGE=1 cypress run",
        "test:e2e": "AOS_PID_FILE=var/aos-cp-e2e.pid WAIT_ON_TIMEOUT=180000 WAIT_ON_INTERVAL=1000 start-server-and-test dev \"http-get://127.0.0.1:8080/api/readyz,http://localhost:3200\" cypress:run",
        "test:e2e:coreml": "AOS_PID_FILE=var/aos-cp-e2e.pid VITE_COREML_EXPORT_UI=1 WAIT_ON_TIMEOUT=180000 WAIT_ON_INTERVAL=1000 start-server-and-test dev \"http-get://127.0.0.1:8080/api/readyz,http://localhost:3200\" \"cypress run --spec e2e/cypress/e2e/ui/backend-selection.cy.ts,e2e/cypress/e2e/ui/training.cy.ts\"",
        "test:e2e:coverage": "CYPRESS_COVERAGE=1 start-server-and-test dev http://localhost:3200 \"cypress run\"",
        "coverage:report": "nyc report --reporter=lcov --reporter=text"
    }
