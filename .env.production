# adapterOS Production Environment Configuration
# ==============================================
#
# IMPORTANT: Copy this file and customize for your deployment.
# DO NOT commit secrets to version control.
#
# Generate secrets:
#   JWT_SECRET: openssl rand -hex 32
#   PROMOTION_SIGNING_KEY: openssl rand -hex 32
#
# PATH POLICY: All paths default to repo-scoped ./var directory.
# For system-wide deployments, uncomment the absolute path overrides below.

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED FOR PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════════

# Enable production mode (enforces security requirements)
AOS_SERVER_PRODUCTION_MODE=true

# JWT secret (REQUIRED - minimum 32 characters)
# Generate with: openssl rand -hex 32
AOS_SECURITY_JWT_SECRET=<REPLACE-WITH-64-CHAR-HEX-STRING>

# JWT algorithm mode (eddsa required for production)
AOS_SECURITY_JWT_MODE=eddsa

# CORS - Comma-separated allowed origins (REQUIRED in production)
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=<REPLACE-WITH-YOUR-ORIGINS>

# Unix domain socket (REQUIRED for production egress policy)
# Default: repo-scoped path
AOS_SERVER_UDS_SOCKET=./var/run/aos.sock
# System-wide override (uncomment for systemd deployments):
# AOS_SERVER_UDS_SOCKET=/var/run/aos/aos.sock

# PF deny rules (REQUIRED for production)
AOS_SECURITY_PF_DENY=true

# ═══════════════════════════════════════════════════════════════════════════════
# RUNTIME DIRECTORY
# ═══════════════════════════════════════════════════════════════════════════════

# Base directory for all runtime data (logs, sockets, db, telemetry)
# Default: repo-scoped path (no sudo required)
AOS_VAR_DIR=./var
# System-wide override (uncomment for systemd deployments):
# AOS_VAR_DIR=/var/lib/aos

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

# Database URL (SQLite with WAL mode)
# Default: repo-scoped path
AOS_DATABASE_URL=sqlite:./var/cp.db?mode=rwc
# System-wide override (uncomment for systemd deployments):
# AOS_DATABASE_URL=sqlite:/var/lib/aos/cp.db?mode=rwc

# Connection pool size
AOS_DATABASE_POOL_SIZE=10

# ═══════════════════════════════════════════════════════════════════════════════
# NETWORK BINDING (behind reverse proxy)
# ═══════════════════════════════════════════════════════════════════════════════

# Bind to localhost only (reverse proxy handles external traffic)
AOS_SERVER_HOST=127.0.0.1
AOS_SERVER_PORT=8080

# ═══════════════════════════════════════════════════════════════════════════════
# MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Path to the model directory
# Default: repo-scoped path
AOS_MODEL_PATH=./var/models/Qwen3.5-27B
# System-wide override (uncomment for systemd deployments):
# AOS_MODEL_PATH=/var/lib/aos/models/Qwen3.5-27B

# Backend preference: coreml (production) or mlx
AOS_MODEL_BACKEND=coreml

# Manifest hash for deterministic execution
# AOS_MANIFEST_HASH=<your-manifest-hash>

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Reduce verbosity for production
RUST_LOG=warn,adapteros=info

# Log format: text or json (json recommended for log aggregation)
AOS_LOG_FORMAT=json

# Log file path (optional)
# Default: repo-scoped path
# AOS_LOG_FILE=./var/logs/aos.log
# System-wide override (uncomment for systemd deployments):
# AOS_LOG_FILE=/var/log/aos/aos.log

# ═══════════════════════════════════════════════════════════════════════════════
# TELEMETRY
# ═══════════════════════════════════════════════════════════════════════════════

# Enable telemetry collection
AOS_TELEMETRY_ENABLED=true

# Telemetry export interval
AOS_TELEMETRY_EXPORT_INTERVAL=60s

# Telemetry directory (defaults to $AOS_VAR_DIR/telemetry)
# AOS_TELEMETRY_DIR=./var/telemetry

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: TLS (if not using reverse proxy)
# ═══════════════════════════════════════════════════════════════════════════════

# TLS certificate and key (uncomment if handling TLS directly)
# AOS_TLS_CERT=/etc/aos/tls/cert.pem
# AOS_TLS_KEY=/etc/aos/tls/key.pem

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: KEYS
# ═══════════════════════════════════════════════════════════════════════════════

# Promotion signing key (auto-generated if not set)
# Generate with: openssl rand -hex 32
# PROMOTION_SIGNING_KEY=<64-char-hex>

# ═══════════════════════════════════════════════════════════════════════════════
# SYSTEM-WIDE DEPLOYMENT OVERRIDES
# ═══════════════════════════════════════════════════════════════════════════════
#
# For systemd/launchd managed deployments requiring absolute paths:
#
# AOS_VAR_DIR=/var/lib/aos
# AOS_SERVER_UDS_SOCKET=/var/run/aos/aos.sock
# AOS_DATABASE_URL=sqlite:/var/lib/aos/cp.db?mode=rwc
# AOS_MODEL_PATH=/var/lib/aos/models/Qwen3.5-27B
# AOS_LOG_FILE=/var/log/aos/aos.log
#
# Required setup for system-wide paths:
#   sudo mkdir -p /var/lib/aos /var/run/aos /var/log/aos
#   sudo chown -R $USER:staff /var/lib/aos /var/run/aos /var/log/aos

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════
#
# Before deploying to production, verify:
#
# [ ] AOS_SERVER_PRODUCTION_MODE=true
# [ ] AOS_SECURITY_JWT_SECRET is set (32+ chars)
# [ ] AOS_SECURITY_JWT_MODE=eddsa
# [ ] ALLOWED_ORIGINS is set (no wildcards)
# [ ] AOS_SERVER_UDS_SOCKET is configured
# [ ] AOS_SECURITY_PF_DENY=true
# [ ] Database path is outside /tmp
# [ ] All debug flags are disabled (AOS_DEBUG_*)
# [ ] Reverse proxy with TLS is configured
# [ ] Log rotation is configured
#
# Validate configuration:
#   aosctl config validate --production --strict
