# AdapterOS Demo Mode Environment
#
# This file is intended to be sourced (or overlaid via `.env.local`) to keep
# demos reproducible without changing runtime logic or code.
#
# It pins:
# - ports (API + UI + service panel)
# - DB path (local SQLite file)
# - log levels
# - common timeouts

# ──────────────────────────────────────────────────────────────────────────────
# Ports
# ──────────────────────────────────────────────────────────────────────────────
AOS_SERVER_HOST=127.0.0.1
AOS_SERVER_PORT=8080
AOS_UI_PORT=3200
AOS_PANEL_PORT=3301

# ──────────────────────────────────────────────────────────────────────────────
# Database (SQLite)
# ──────────────────────────────────────────────────────────────────────────────
AOS_DATABASE_URL=sqlite:var/aos-demo.sqlite3

# ──────────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────────
# Coarse log level (used by some components/config views)
AOS_LOG_LEVEL=info
# Rust tracing filter (supports per-module overrides)
RUST_LOG=info,adapteros=debug

# ──────────────────────────────────────────────────────────────────────────────
# Timeouts
# ──────────────────────────────────────────────────────────────────────────────
# Duration values accept suffixes like: 30s, 5m
AOS_DATABASE_TIMEOUT=30s
AOS_WORKER_SHUTDOWN_TIMEOUT=30s
# Integer seconds
AOS_DOWNLOAD_TIMEOUT_SECS=300
