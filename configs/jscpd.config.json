{
  "minTokens": 70,
  "threshold": 0,
  "reporters": ["console", "json", "html", "markdown"],
  "mode": "strict",
  "gitignore": true,
  "ignore": [
    "**/.git/**",
    "**/.venv/**",
    "**/node_modules/**",
    "**/target/**",
    "**/var/**",
    "**/dist/**",
    "**/.cache/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.build/**",
    "**/*.lock",
    "**/*.min.*",
    "**/generated/**",
    "**/coverage/**"
  ]
}
