{
  "minTokens": 70,
  "threshold": 10,
  "reporters": ["console", "json", "html", "markdown"],
  "mode": "strict",
  "gitignore": true,
  "progress": true,
  "ignore": [
    "**/.git/**",
    "**/.codex/**",
    "**/.venv/**",
    "**/node_modules/**",
    "**/target/**",
    "**/var/**",
    "**/dist/**",
    "**/crates/adapteros-server/static/**",
    "**/.cache/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.build/**",
    "**/*.lock",
    "**/*.min.*",
    "**/generated/**",
    "**/coverage/**",
    "**/deprecated/**",
    "**/baselines/**",
    "**/golden_runs/**",
    "**/ai_slop_reports/**",
    "**/test_data/**",
    "**/adapters/**",
    "**/artifacts/**",
    "**/installer/build/**",
    "**/fuzz/target/**",
    "**/xtask/target/**",
    "**/test-status-writer/target/**",
    "**/test-config-precedence/target/**",
    "**/*.aos",
    "**/*.safetensors",
    "**/*.pem",
    "**/*.sig"
  ]
}
