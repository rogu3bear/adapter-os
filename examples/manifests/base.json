  "telemetry": {
    "schema_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    "sampling": {
      "token": 0.05,
      "router": 1.0,
      "inference": 1.0
    },
    "router_full_tokens": 128,
    "bundle": {
      "max_events": 500000,
      "max_bytes": 268435456
    }
  },
  "policies": {
    "egress": {
      "mode": "deny_all",
      "serve_requires_pf": true,
      "allow_tcp": false,
      "allow_udp": false,
      "uds_paths": ["/var/run/aos/<tenant>/*.sock"]
