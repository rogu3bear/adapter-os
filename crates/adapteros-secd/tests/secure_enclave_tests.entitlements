<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Disable app sandbox for hardware access -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Keychain access groups for Secure Enclave key storage -->
	<key>keychain-access-groups</key>
	<array>
		<string>3UB9P555B8.com.adapteros.secd</string>
		<string>3UB9P555B8.com.adapteros.*</string>
		<string>3UB9P555B8.*</string>
	</array>

	<!-- Application groups for inter-process communication -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>3UB9P555B8.group.com.adapteros.secd</string>
	</array>

	<!-- Smart card entitlement for Secure Enclave access -->
	<key>com.apple.security.smartcard</key>
	<true/>

	<!-- Device-specific access for Secure Enclave -->
	<key>com.apple.security.device.secure-enclave</key>
	<true/>

	<!-- Allow file access for keychain storage -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
