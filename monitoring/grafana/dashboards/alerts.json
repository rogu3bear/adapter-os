{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "adapteros_alerts_active_total",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "title": "Active Alerts",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(adapteros_alerts{severity=\"critical\", status=\"firing\"})",
          "legendFormat": "Critical",
          "refId": "A"
        }
      ],
      "title": "Critical Alerts",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "increase(adapteros_policy_violations_total{tenant_id=~\"$tenant_id\"}[24h])",
          "legendFormat": "Violations",
          "refId": "A"
        }
      ],
      "title": "Policy Violations (24h)",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(mplora_http_requests_total{status=~\"5..\"}[24h])) / sum(rate(mplora_http_requests_total[24h])))) * 100",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ],
      "title": "Service Availability (24h)",
      "type": "gauge"
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by(severity) (adapteros_alerts{status=\"firing\", tenant_id=~\"$tenant_id\"})",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "title": "Alerts by Severity",
      "type": "piechart"
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by(alertname) (adapteros_alerts{status=\"firing\", tenant_id=~\"$tenant_id\"})",
          "legendFormat": "{{alertname}}",
          "refId": "A"
        }
      ],
      "title": "Alert Timeline",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 7,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "targets": [
        {
          "expr": "adapteros_alerts{status=\"firing\", tenant_id=~\"$tenant_id\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Active Alerts Detail",
      "type": "table",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "Value": true },
            "indexByName": {},
            "renameByName": {
              "alertname": "Alert",
              "severity": "Severity",
              "tenant_id": "Tenant",
              "worker_id": "Worker",
              "status": "Status"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "color": "red", "index": 0 } } },
                  { "type": "value", "options": { "warning": { "color": "yellow", "index": 1 } } },
                  { "type": "value", "options": { "info": { "color": "blue", "index": 2 } } }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "id": 8,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "rate(adapteros_policy_violations_total{tenant_id=~\"$tenant_id\"}[5m])",
          "legendFormat": "{{policy_pack}}",
          "refId": "A"
        }
      ],
      "title": "Policy Violation Rate by Pack",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "ops"
        }
      }
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(mplora_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99 Latency",
          "refId": "A"
        },
        {
          "expr": "0.5",
          "legendFormat": "SLO Threshold (500ms)",
          "refId": "B"
        }
      ],
      "title": "Latency SLO (p99 < 500ms)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 0, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO Threshold (500ms)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 26 },
      "id": 10,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(mplora_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(mplora_http_requests_total[5m])) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        },
        {
          "expr": "1",
          "legendFormat": "SLO Threshold (1%)",
          "refId": "B"
        }
      ],
      "title": "Error Rate SLO (< 1%)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO Threshold (1%)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["adapteros", "alerts", "slo"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(adapteros_adapters_by_state, tenant_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": false,
        "name": "tenant_id",
        "options": [],
        "query": { "query": "label_values(adapteros_adapters_by_state, tenant_id)", "refId": "A" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "AdapterOS Alerts & SLOs",
  "uid": "adapteros-alerts",
  "version": 1,
  "weekStart": ""
}
