{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(mplora_http_requests_total{path=~\"/v1/infer.*\"}[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "title": "Inference Rate",
      "type": "stat",
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(mplora_http_request_duration_seconds_bucket{path=~\"/v1/infer.*\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "title": "p99 Latency",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(mplora_http_requests_total{path=~\"/v1/infer.*\", status=~\"5..\"}[5m])) / sum(rate(mplora_http_requests_total{path=~\"/v1/infer.*\"}[5m])) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "mplora_jobs_active{kind=\"inference\"}",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "title": "Queue Depth",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(mplora_http_request_duration_seconds_bucket{path=~\"/v1/infer.*\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(mplora_http_request_duration_seconds_bucket{path=~\"/v1/infer.*\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(mplora_http_request_duration_seconds_bucket{path=~\"/v1/infer.*\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Latency Percentiles",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 0, "lineWidth": 2 },
          "unit": "s"
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": {
        "calculate": true,
        "cellGap": 1,
        "color": { "exponent": 0.5, "fill": "#b4ff00", "mode": "scheme", "reverse": false, "scale": "exponential", "scheme": "YlOrRd", "steps": 64 },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "show": true, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "s" }
      },
      "targets": [
        {
          "expr": "sum by(le) (rate(mplora_http_request_duration_seconds_bucket{path=~\"/v1/infer.*\"}[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Latency Heatmap",
      "type": "heatmap"
    },
    {
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by(status) (rate(mplora_http_requests_total{path=~\"/v1/infer.*\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Request Distribution by Status",
      "type": "piechart"
    },
    {
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 12 },
      "id": 8,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by(status) (rate(mplora_http_requests_total{path=~\"/v1/infer.*\", status=~\"4..|5..\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Error Timeline",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } },
          "unit": "reqps"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["adapteros", "inference"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(adapteros_adapters_by_state, tenant_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": false,
        "name": "tenant_id",
        "options": [],
        "query": { "query": "label_values(adapteros_adapters_by_state, tenant_id)", "refId": "A" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "adapterOS Inference Performance",
  "uid": "adapteros-inference",
  "version": 1,
  "weekStart": ""
}
