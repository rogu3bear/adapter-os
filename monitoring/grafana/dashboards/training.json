{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "adapteros_training_jobs_active{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "title": "Active Training Jobs",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "increase(adapteros_training_jobs_completed_total{tenant_id=~\"$tenant_id\"}[24h])",
          "legendFormat": "Completed",
          "refId": "A"
        }
      ],
      "title": "Jobs Completed (24h)",
      "type": "stat"
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "increase(adapteros_training_jobs_failed_total{tenant_id=~\"$tenant_id\"}[24h])",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ],
      "title": "Jobs Failed (24h)",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "avg(adapteros_training_job_duration_seconds{tenant_id=~\"$tenant_id\"})",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ],
      "title": "Avg Job Duration",
      "type": "stat",
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "adapteros_training_epoch_current{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{job_id}} - Epoch",
          "refId": "A"
        }
      ],
      "title": "Training Progress (Epochs)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "adapteros_training_loss{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{job_id}} - Loss",
          "refId": "A"
        }
      ],
      "title": "Training Loss",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 0, "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "options": {
        "calculate": true,
        "cellGap": 1,
        "color": { "mode": "scheme", "scheme": "Blues", "steps": 64 },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "tooltip": { "show": true, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "s" }
      },
      "targets": [
        {
          "expr": "sum by(le) (rate(adapteros_training_job_duration_seconds_bucket{tenant_id=~\"$tenant_id\"}[1h]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Job Duration Distribution",
      "type": "heatmap"
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "adapteros_gpu_utilization{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "GPU {{gpu_id}}",
          "refId": "A"
        },
        {
          "expr": "adapteros_ane_utilization{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "ANE",
          "refId": "B"
        }
      ],
      "title": "Accelerator Utilization",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 9,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "targets": [
        {
          "expr": "adapteros_training_job_info{tenant_id=~\"$tenant_id\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Recent Training Jobs",
      "type": "table",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "Value": true },
            "indexByName": {},
            "renameByName": {
              "job_id": "Job ID",
              "adapter_id": "Adapter",
              "tenant_id": "Tenant",
              "status": "Status",
              "base_model": "Base Model",
              "dataset_id": "Dataset"
            }
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["adapteros", "training"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(adapteros_adapters_by_state, tenant_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": false,
        "name": "tenant_id",
        "options": [],
        "query": { "query": "label_values(adapteros_adapters_by_state, tenant_id)", "refId": "A" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "AdapterOS Training",
  "uid": "adapteros-training",
  "version": 1,
  "weekStart": ""
}
