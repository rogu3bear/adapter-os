            ]
          }
        }
      },
      "targets": [
        { "expr": "adapteros_db_index_health_status", "legendFormat": "status", "refId": "A" }
      ],
      "title": "Index Health Status (0/1/2)",
      "type": "stat"
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
