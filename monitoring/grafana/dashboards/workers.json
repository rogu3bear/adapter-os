{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "adapteros_lora_workers_active",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "title": "Active Workers",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(adapteros_worker_adapters_loaded{tenant_id=~\"$tenant_id\"})",
          "legendFormat": "Loaded",
          "refId": "A"
        }
      ],
      "title": "Adapters Loaded",
      "type": "stat"
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(adapteros_worker_memory_used_bytes{tenant_id=~\"$tenant_id\"})",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "title": "Total Memory Used",
      "type": "stat",
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(adapteros_worker_memory_available_bytes)",
          "legendFormat": "Available",
          "refId": "A"
        }
      ],
      "title": "Memory Available",
      "type": "stat",
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "increase(adapteros_worker_model_loads_total{tenant_id=~\"$tenant_id\"}[1h])",
          "legendFormat": "Loads",
          "refId": "A"
        }
      ],
      "title": "Model Loads (1h)",
      "type": "stat"
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "increase(adapteros_worker_model_unloads_total{tenant_id=~\"$tenant_id\"}[1h])",
          "legendFormat": "Unloads",
          "refId": "A"
        }
      ],
      "title": "Model Unloads (1h)",
      "type": "stat"
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "adapteros_worker_memory_used_bytes{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{worker_id}} Used",
          "refId": "A"
        },
        {
          "expr": "adapteros_worker_memory_available_bytes{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{worker_id}} Available",
          "refId": "B"
        }
      ],
      "title": "Worker Memory Usage",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "bytes"
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 8,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "adapteros_worker_adapters_loaded{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{worker_id}}",
          "refId": "A"
        }
      ],
      "title": "Adapters per Worker",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 9,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "rate(adapteros_worker_model_loads_total{tenant_id=~\"$tenant_id\"}[5m])",
          "legendFormat": "{{worker_id}} - Loads",
          "refId": "A"
        },
        {
          "expr": "rate(adapteros_worker_model_unloads_total{tenant_id=~\"$tenant_id\"}[5m])",
          "legendFormat": "{{worker_id}} - Unloads",
          "refId": "B"
        }
      ],
      "title": "Model Load/Unload Rate",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 0, "lineWidth": 2 },
          "unit": "ops"
        }
      }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "adapteros_worker_by_state{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "title": "Workers by State",
      "type": "piechart"
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "adapteros_worker_inference_queue_depth{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{worker_id}}",
          "refId": "A"
        }
      ],
      "title": "Inference Queue Depth",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "lineWidth": 1 },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(adapteros_worker_inference_latency_seconds_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, worker_id))",
          "legendFormat": "{{worker_id}} p95",
          "refId": "A"
        }
      ],
      "title": "Worker Inference Latency (p95)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 0, "lineWidth": 2 },
          "unit": "s"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["adapteros", "workers"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(adapteros_adapters_by_state, tenant_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": false,
        "name": "tenant_id",
        "options": [],
        "query": { "query": "label_values(adapteros_adapters_by_state, tenant_id)", "refId": "A" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "AdapterOS Workers",
  "uid": "adapteros-workers",
  "version": 1,
  "weekStart": ""
}
