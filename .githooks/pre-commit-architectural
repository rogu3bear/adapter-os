#!/bin/bash
# Pre-commit hook for architectural pattern validation
# Checks for citation format, architectural patterns, and error types

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Running architectural pre-commit checks..."

# Get list of staged Rust files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}вњ“ No Rust files staged, skipping architectural checks${NC}"
    exit 0
fi

VIOLATIONS=0

# Check 1: Citation format validation
echo "Checking citation format..."
CITATION_PATTERN='гЂђ[0-9]{4}-[0-9]{2}-[0-9]{2}вЂ [^вЂ ]+вЂ [^гЂ‘]+гЂ‘'
for file in $STAGED_FILES; do
    # Check if file is in services directory (extracted code should have citations)
    if [[ "$file" == *"/services/"* ]]; then
        # Check for functions without citations (simplified check)
        if grep -q "^pub fn\|^pub async fn" "$file" 2>/dev/null; then
            # Check if file has at least one citation
            if ! grep -q "$CITATION_PATTERN" "$file" 2>/dev/null; then
                echo -e "${YELLOW}вљ  Warning: $file may be missing citations${NC}"
            fi
        fi
    fi
done

# Check 2: Architectural pattern checks using lint tool
echo "Running architectural lint..."
if command -v cargo &> /dev/null; then
    # Build lint tool if needed
    if [ ! -f "target/release/adapteros-lint" ]; then
        echo "Building architectural lint tool..."
        cargo build -p adapteros-lint --release --quiet 2>&1 || {
            echo -e "${YELLOW}вљ  Could not build lint tool, skipping architectural checks${NC}"
            exit 0
        }
    fi
    
    # Check staged handler files
    HANDLER_FILES=$(echo "$STAGED_FILES" | grep "handlers" || true)
    if [ -n "$HANDLER_FILES" ]; then
        for file in $HANDLER_FILES; do
            if ./target/release/adapteros-lint check "$file" 2>&1 | grep -q "violation"; then
                echo -e "${RED}вњ— Architectural violations found in $file${NC}"
                ./target/release/adapteros-lint check "$file" 2>&1 | grep -A 5 "violation" || true
                VIOLATIONS=$((VIOLATIONS + 1))
            fi
        done
    fi
else
    echo -e "${YELLOW}вљ  cargo not found, skipping architectural lint${NC}"
fi

# Check 3: Error type validation (AosError vs generic errors)
echo "Checking error types..."
for file in $STAGED_FILES; do
    # Check for generic error types in production code (not tests)
    if [[ "$file" != *"/test"* ]] && [[ "$file" != *"/tests/"* ]]; then
        if grep -q "Box<dyn.*Error\|anyhow::Error" "$file" 2>/dev/null; then
            # Check if it's in a test function or acceptable context
            if ! grep -B 5 "Box<dyn.*Error\|anyhow::Error" "$file" 2>/dev/null | grep -q "#\[test\]\|#\[cfg(test)\]"; then
                echo -e "${YELLOW}вљ  Warning: $file may use generic error types (should use AosError)${NC}"
            fi
        fi
    fi
done

# Summary
if [ $VIOLATIONS -eq 0 ]; then
    echo -e "${GREEN}вњ“ All architectural checks passed${NC}"
    exit 0
else
    echo -e "${RED}вњ— Found $VIOLATIONS architectural violation(s)${NC}"
    echo -e "${YELLOW}Fix violations before committing, or use --no-verify to skip${NC}"
    exit 1
fi

