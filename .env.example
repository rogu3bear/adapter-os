# AdapterOS Environment Configuration
# Copy this file to .env and customize for your setup
#
# Configuration precedence: CLI args > Environment > .env > Defaults
# Docs: docs/PRD-CONFIG-001-unified-configuration-system.md

# ═══════════════════════════════════════════════════════════════════════════════
# MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Path to the model directory (required for inference)
# Supports HuggingFace-style directories with config.json and model weights
AOS_MODEL_PATH=./models/qwen2.5-7b-mlx

# Backend preference: auto, coreml, metal, mlx
# - auto: Automatically select best available backend (CoreML > Metal > MLX)
# - coreml: Apple Neural Engine acceleration (production, guaranteed determinism)
# - metal: Metal GPU backend (fallback, guaranteed determinism)
# - mlx: MLX backend (research/training, HKDF-seeded determinism)
AOS_MODEL_BACKEND=auto

# Model architecture (auto-detected from config.json if not set)
# AOS_MODEL_ARCHITECTURE=qwen2

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Server bind address and port
# AOS_SERVER_HOST=127.0.0.1
# AOS_SERVER_PORT=8080

# Number of worker threads (default: number of CPU cores)
# AOS_SERVER_WORKERS=4

# Unix domain socket for production mode (required when AOS_SERVER_PRODUCTION_MODE=true)
# AOS_SERVER_UDS_SOCKET=/var/run/aos/aos.sock

# Enable production mode (enforces security requirements)
# AOS_SERVER_PRODUCTION_MODE=false

# UI Development Server Port (default: 3200)
# Used only by: pnpm dev (Vite development server)
# AOS_UI_PORT=3200

# Service Panel Management Port (default: 3301)
# Used by: ui/server.js (Node.js service manager)
# AOS_PANEL_PORT=3301

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Database URL (SQLite with WAL mode)
AOS_DATABASE_URL=sqlite:var/aos-cp.sqlite3

# Connection pool size
# AOS_DATABASE_POOL_SIZE=10

# Query timeout in seconds
# AOS_DATABASE_TIMEOUT=30

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# JWT authentication mode: eddsa (production) or hs256 (development)
# AOS_SECURITY_JWT_MODE=eddsa

# JWT secret (required - generate with: openssl rand -base64 32)
# AOS_SECURITY_JWT_SECRET=your-secret-here

# JWT token TTL (e.g., 8h, 1d)
# AOS_SECURITY_JWT_TTL=8h

# Enable PF deny rules (required in production)
# AOS_SECURITY_PF_DENY=false

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Log level: trace, debug, info, warn, error
# Also supports per-module levels: info,adapteros=debug,adapteros_lora_worker=trace
RUST_LOG=info,adapteros=debug

# Log format: text, json
# AOS_LOG_FORMAT=text

# Log file path (optional, logs to stderr by default)
# AOS_LOG_FILE=/var/log/aos/aos.log

# ═══════════════════════════════════════════════════════════════════════════════
# MEMORY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Memory headroom percentage to maintain (0.0-1.0)
# AOS_MEMORY_HEADROOM_PCT=0.15

# Eviction threshold percentage (0.0-1.0)
# AOS_MEMORY_EVICTION_THRESHOLD=0.85

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Enable/disable specific backends
# AOS_BACKEND_COREML_ENABLED=true
# AOS_BACKEND_METAL_ENABLED=true
# AOS_BACKEND_MLX_ENABLED=true

# GPU device index (for multi-GPU systems)
# AOS_BACKEND_GPU_INDEX=0

# ═══════════════════════════════════════════════════════════════════════════════
# MLX BACKEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Path to MLX model directory (alternative to AOS_MODEL_PATH for MLX-specific models)
# Must contain: config.json, tokenizer.json, and model weights (.safetensors)
# Example: ./models/qwen2.5-7b-mlx or ./models/llama-3-8b-mlx
# AOS_MLX_FFI_MODEL=./models/qwen2.5-7b-mlx

# MLX-specific memory settings
# Maximum memory allocation for MLX operations (in bytes, 0 = unlimited)
# AOS_MLX_MAX_MEMORY=0

# Enable MLX memory pool for reduced allocation overhead
# AOS_MLX_MEMORY_POOL_ENABLED=true

# MLX compute precision: float32, float16, bfloat16
# AOS_MLX_PRECISION=float16

# ═══════════════════════════════════════════════════════════════════════════════
# TELEMETRY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Enable telemetry collection
# AOS_TELEMETRY_ENABLED=true

# Telemetry export interval
# AOS_TELEMETRY_EXPORT_INTERVAL=60s

# ═══════════════════════════════════════════════════════════════════════════════
# FEDERATION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Enable federation
# AOS_FEDERATION_ENABLED=false

# Federation node ID (auto-generated if not set)
# AOS_FEDERATION_NODE_ID=node-001

# Comma-separated list of peer addresses
# AOS_FEDERATION_PEERS=peer1.example.com:9000,peer2.example.com:9000

# ═══════════════════════════════════════════════════════════════════════════════
# DEBUG FLAGS (development only - do not use in production)
# ═══════════════════════════════════════════════════════════════════════════════

# Enable deterministic execution debug logging
# AOS_DEBUG_DETERMINISTIC=false

# Skip kernel signature verification (DANGEROUS - development only)
# AOS_DEBUG_SKIP_KERNEL_SIG=false

# ═══════════════════════════════════════════════════════════════════════════════
# LEGACY VARIABLES (deprecated - migrate using: aosctl config migrate)
# ═══════════════════════════════════════════════════════════════════════════════
# The following variables are deprecated but still supported for backward compatibility:
#   DATABASE_URL          -> AOS_DATABASE_URL
#   MLX_PATH              -> AOS_MLX_PATH
#   ADAPTEROS_SERVER_PORT -> AOS_SERVER_PORT
#   ADAPTEROS_SERVER_HOST -> AOS_SERVER_HOST
#   AOS_MLX_FFI_MODEL     -> AOS_MODEL_PATH
#   AOS_GPU_INDEX         -> AOS_BACKEND_GPU_INDEX
