# AdapterOS Environment Configuration Template
# Copy this file to .env and update with your values

# Database Configuration (Required)
DATABASE_URL=sqlite://var/aos-cp.sqlite3
RUST_LOG=info,adapteros=debug

# Development/Production Mode
AOS_ENV=development

# Server Configuration
AOS_SERVER_HOST=127.0.0.1
AOS_SERVER_PORT=8080

# Security Configuration (Change in production!)
AOS_JWT_SECRET=your-jwt-secret-key-change-in-production
AOS_ENCRYPTION_KEY=your-encryption-key-change-in-production

# Model Configuration
# Path to model manifest file
AOS_MANIFEST_PATH=models/qwen2.5-7b-mlx/manifest.json
AOS_MODEL_PATH=models/qwen2.5-7b-mlx
AOS_MAX_TOKENS=512
AOS_TEMPERATURE=0.7

# Dataset Storage Configuration
DATASET_STORAGE_PATH=var/datasets

# Worker Configuration
AOS_WORKER_UDS_PATH=/tmp/aos-worker.sock
AOS_MAX_CONCURRENT_REQUESTS=10

# Telemetry Configuration
AOS_TELEMETRY_ENABLED=true
AOS_TELEMETRY_SAMPLE_RATE=0.1

# Optional: Override config file location
# AOS_CONFIG_PATH=configs/cp.toml

# Optional: Feature Flags
# AOS_ENABLE_DETERMINISTIC=true
# AOS_SKIP_PF_CHECK=false